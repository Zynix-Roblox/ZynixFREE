    {"LeftUpperArm", "LeftLowerArm"},
    {"LeftLowerArm", "LeftHand"},
    {"UpperTorso", "RightUpperArm"},
    {"RightUpperArm", "RightLowerArm"},
    {"RightLowerArm", "RightHand"},
    {"LowerTorso", "LeftUpperLeg"},
    {"LeftUpperLeg", "LeftLowerLeg"},
    {"LeftLowerLeg", "LeftFoot"},
    {"LowerTorso", "RightUpperLeg"},
    {"RightUpperLeg", "RightLowerLeg"},
    {"RightLowerLeg", "RightFoot"},
}

-- Triggerbot anti-spam
local lastTriggerTime = 0

-- Movement helpers
local flyBodyVelocity = nil

RunService.RenderStepped:Connect(function(deltaTime)
    if not State.Unlocked then return end

    local mouseLoc = UserInputService:GetMouseLocation()

    -- FOV Circle
    FOVCircle.Visible = State.ShowFOV
    if State.ShowFOV then
        FOVCircle.Position = mouseLoc
        FOVCircle.Radius = State.AimbotFOV
        FOVCircle.Color = State.RainbowFOV and Color3fromHSV(tick() % 5 / 5, 1, 1) or CONFIG.Accent
    end

    -- Aimbot target selection
    local closestPlayer, minDist = nil, State.AimbotFOV
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local char = player.Character
            local root = char:FindFirstChild("HumanoidRootPart")
            local targetPart = char:FindFirstChild(State.AimbotTarget) or root

            if root and targetPart then
                local pos, vis = Camera:WorldToViewportPoint(targetPart.Position)

                if vis then
                    local dist = (Vector2new(pos.X, pos.Y) - mouseLoc).Magnitude
                    if dist < minDist then
                        -- Team check
                        if not State.AimbotTeam or player.Team ~= LocalPlayer.Team then
                            -- Wall check
                            if not State.AimbotWall or #Camera:GetPartsObscuringTarget({targetPart.Position}, {LocalPlayer.Character, char}) == 0 then
                                minDist = dist
                                closestPlayer = player
                            end
                        end
                    end
                end
            end
        end
    end

    -- Aimbot execution
    if State.Aimbot and closestPlayer and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local targetChar = closestPlayer.Character
        local targetPart = targetChar:FindFirstChild(State.AimbotTarget) or targetChar:FindFirstChild("HumanoidRootPart")
        if targetPart then
            -- Velocity prediction
            local predictedPos = targetPart.Position
            if State.AimbotPrediction > 0 and targetPart.Velocity then
                predictedPos = predictedPos + targetPart.Velocity * (State.AimbotPrediction / 10)
            end
            local pos = Camera:WorldToViewportPoint(predictedPos)
            -- Hard lock with smoothness
            mousemoverel((pos.X - mouseLoc.X) / State.AimbotSmooth, (pos.Y - mouseLoc.Y) / State.AimbotSmooth)
        end
    end

    -- Triggerbot
    if State.Triggerbot then
        local now = tick()
        if now - lastTriggerTime >= State.TriggerbotDelay / 1000 then
            local mouseTarget = LocalPlayer:GetMouse().Target
            if mouseTarget and mouseTarget.Parent and mouseTarget.Parent:FindFirstChild("Humanoid") then
                local targetPlayer = Players:GetPlayerFromCharacter(mouseTarget.Parent)
                if targetPlayer and targetPlayer ~= LocalPlayer then
                    if not State.AimbotTeam or targetPlayer.Team ~= LocalPlayer.Team then
                        mouse1click()
                        lastTriggerTime = now
                    end
                end
            end
        end
    end

    -- Hitbox Expander logic
    local myChar = LocalPlayer.Character
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
        local root = myChar.HumanoidRootPart
        local originalSize = Vector3new(2, 2, 1) -- default fallback; we'll cache real original later
        if not root:GetAttribute("OriginalSize") then
            root:SetAttribute("OriginalSize", root.Size)
        end
        local origSize = root:GetAttribute("OriginalSize")
        local targetSize = State.HitboxExpander and origSize + Vector3new(State.HitboxExpandSize, State.HitboxExpandSize, State.HitboxExpandSize) or origSize
        -- Smooth transition
        local smoothSpeed = 15
        root.Size = root.Size:Lerp(targetSize, math.min(deltaTime * smoothSpeed, 1))

        -- Hitbox visuals
        local showVisuals = State.HitboxExpander and State.HitboxVisuals
        HitboxOuter.Visible = showVisuals
        HitboxInner.Visible = showVisuals
        if showVisuals then
            local rootScreenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
            if onScreen then
                -- Compute screen-space radii based on extents
                local function getRadiusFromSize(size)
                    -- Half diagonal of the part's size projected
                    local halfSize = size * 0.5
                    local corners = {
                        root.CFrame * Vector3new(halfSize.X, halfSize.Y, halfSize.Z),
                        root.CFrame * Vector3new(-halfSize.X, halfSize.Y, halfSize.Z),
                        root.CFrame * Vector3new(halfSize.X, -halfSize.Y, halfSize.Z),
                        root.CFrame * Vector3new(-halfSize.X, -halfSize.Y, halfSize.Z),
                        root.CFrame * Vector3new(halfSize.X, halfSize.Y, -halfSize.Z),
                        root.CFrame * Vector3new(-halfSize.X, halfSize.Y, -halfSize.Z),
                        root.CFrame * Vector3new(halfSize.X, -halfSize.Y, -halfSize.Z),
                        root.CFrame * Vector3new(-halfSize.X, -halfSize.Y, -halfSize.Z),
                    }
                    local maxDist = 0
                    local center2D = Vector2new(rootScreenPos.X, rootScreenPos.Y)
                    for _, corner in ipairs(corners) do
                        local corner2D, vis = Camera:WorldToViewportPoint(corner)
                        if vis then
                            local d = (Vector2new(corner2D.X, corner2D.Y) - center2D).Magnitude
                            if d > maxDist then maxDist = d end
                        end
                    end
                    return maxDist
                end

                local expandedRadius = getRadiusFromSize(targetSize)
                local originalRadius = getRadiusFromSize(origSize)

                HitboxOuter.Position = Vector2new(rootScreenPos.X, rootScreenPos.Y)
                HitboxOuter.Radius = expandedRadius
                HitboxInner.Position = Vector2new(rootScreenPos.X, rootScreenPos.Y)
                HitboxInner.Radius = originalRadius
            else
                HitboxOuter.Visible = false
                HitboxInner.Visible = false
            end
        end
    end

    -- ESP Loop
    for _, player in ipairs(Players:GetPlayers()) do
        local esp = getESP(player)
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local char = player.Character
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                local color = State.ESPRainbow and Color3fromHSV(tick() % 5 / 5, 1, 1) or CONFIG.Accent

                -- Bounding box for ESP (perfect fit)
                local minBounds, maxBounds = getCharacterBounds(char)
                local corners = {
                    Vector3new(minBounds.X, minBounds.Y, minBounds.Z),
                    Vector3new(minBounds.X, minBounds.Y, maxBounds.Z),
                    Vector3new(minBounds.X, maxBounds.Y, minBounds.Z),
                    Vector3new(minBounds.X, maxBounds.Y, maxBounds.Z),
                    Vector3new(maxBounds.X, minBounds.Y, minBounds.Z),
                    Vector3new(maxBounds.X, minBounds.Y, maxBounds.Z),
                    Vector3new(maxBounds.X, maxBounds.Y, minBounds.Z),
                    Vector3new(maxBounds.X, maxBounds.Y, maxBounds.Z),
                }
                local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
                local anyOnScreen = false
                for _, corner in ipairs(corners) do
                    local screenPoint, onScreen = Camera:WorldToViewportPoint(corner)
                    if onScreen then
                        anyOnScreen = true
                        if screenPoint.X < minX then minX = screenPoint.X end
                        if screenPoint.Y < minY then minY = screenPoint.Y end
                        if screenPoint.X > maxX then maxX = screenPoint.X end
                        if screenPoint.Y > maxY then maxY = screenPoint.Y end
                    end
                end

                if anyOnScreen then
                    -- Box
                    if State.ESPBox then
                        esp.Box.Visible = true
                        esp.Box.Position = Vector2new(minX, minY)
                        esp.Box.Size = Vector2new(maxX - minX, maxY - minY)
                        esp.Box.Color = color
                        esp.Box.Thickness = 1.5
                    else
                        esp.Box.Visible = false
                    end

                    -- Name
                    if State.ESPName then
                        esp.Name.Visible = true
                        esp.Name.Text = player.Name
                        esp.Name.Size = 15
                        esp.Name.Center = true
                        esp.Name.Outline = true
                        esp.Name.Position = Vector2new((minX + maxX) / 2, minY - 18)
                        esp.Name.Color = CONFIG.Text
                    else
                        esp.Name.Visible = false
                    end

                    -- Tracer
                    if State.ESPTracer then
                        esp.Tracer.Visible = true
                        esp.Tracer.From = Vector2new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        esp.Tracer.To = Vector2new((minX + maxX) / 2, maxY)
                        esp.Tracer.Color = color
                        esp.Tracer.Thickness = 1.2
                    else
                        esp.Tracer.Visible = false
                    end

                    -- Skeleton
                    if State.ESPSkeleton then
                        -- Detect skeleton type
                        local isR15 = char:FindFirstChild("LowerTorso") ~= nil
                        local connections = isR15 and R15Connections or {
                            {"Head", "Torso"},
                            {"Torso", "Left Arm"},
                            {"Torso", "Right Arm"},
                            {"Torso", "Left Leg"},
                            {"Torso", "Right Leg"},
                        }
                        for i, conn in ipairs(connections) do
                            local partA = char:FindFirstChild(conn[1])
                            local partB = char:FindFirstChild(conn[2])
                            local line = esp.SkeletonLines[i]
                            if partA and partB then
                                local posA = Camera:WorldToViewportPoint(partA.Position)
                                local posB = Camera:WorldToViewportPoint(partB.Position)
                                line.Visible = true
                                line.From = Vector2new(posA.X, posA.Y)
                                line.To = Vector2new(posB.X, posB.Y)
                                line.Color = color
                                line.Thickness = 1.2
                            else
                                line.Visible = false
                            end
                        end
                        -- Hide unused lines
                        for i = #connections+1, #esp.SkeletonLines do
                            esp.SkeletonLines[i].Visible = false
                        end
                    else
                        for _, line in ipairs(esp.SkeletonLines) do line.Visible = false end
                    end
                else
                    esp.Box.Visible = false
                    esp.Name.Visible = false
                    esp.Tracer.Visible = false
                    for _, line in ipairs(esp.SkeletonLines) do line.Visible = false end
                end
            end
        else
            esp.Box.Visible = false
            esp.Name.Visible = false
            esp.Tracer.Visible = false
            for _, line in ipairs(esp.SkeletonLines) do line.Visible = false end
        end
    end

    -- Movement
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local hum = LocalPlayer.Character.Humanoid
        local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        hum.WalkSpeed = State.Speed

        if State.Fly and root then
            if not flyBodyVelocity or flyBodyVelocity.Parent ~= root then
                if flyBodyVelocity then flyBodyVelocity:Destroy() end
                flyBodyVelocity = Instance.new("BodyVelocity")
                flyBodyVelocity.MaxForce = Vector3new(1e5, 1e5, 1e5)
                flyBodyVelocity.Parent = root
                flyBodyVelocity.Velocity = Vector3new()
                hum.PlatformStand = true
            end
            local moveVec = Vector3new(0, 0, 0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVec = moveVec + Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVec = moveVec - Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVec = moveVec - Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVec = moveVec + Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveVec = moveVec + Vector3new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveVec = moveVec - Vector3new(0, 1, 0) end
            flyBodyVelocity.Velocity = moveVec * State.FlySpeed
        else
            if flyBodyVelocity then
                flyBodyVelocity:Destroy()
                flyBodyVelocity = nil
            end
            if hum.PlatformStand then hum.PlatformStand = false end
        end

        if State.Bhop and hum.FloorMaterial ~= Enum.Material.Air then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end

        if State.Spin and root then
            root.CFrame = root.CFrame * CFAngles(0, mathrad(25 * deltaTime * 60), 0) -- smooth rotation
        end
    end
end)

-- NoClip and Fullbright handled in Stepped for reliability
RunService.Stepped:Connect(function()
    if State.Unlocked and State.NoClip and LocalPlayer.Character then
        for _, v in ipairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
    if State.Unlocked and State.Fullbright then
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        Lighting.GlobalShadows = false
    else
        if not State.Fullbright then
            Lighting.Brightness = 1
            Lighting.ClockTime = 12
            Lighting.GlobalShadows = true
        end
    end
end)

-- Cleanup on script end
local function cleanup()
    for p, _ in pairs(ESP_Data) do
        cleanESP(p)
    end
    if flyBodyVelocity then flyBodyVelocity:Destroy() end
    ScreenGui:Destroy()
end

-- Protect against errors
local success, err = pcall(function()
    print("Zynix loaded successfully! Welcome.")
end)
if not success then warn("Zynix error: " .. tostring(err)) end
