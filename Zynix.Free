-- ==================== AUTH LOGIC ====================
KeyBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == CONFIG.Key then
        State.Unlocked = true
        -- Hide auth frame
        KeyFrame.Visible = false
        -- Show main GUI and watermark
        Main.Visible = true
        Watermark.Visible = true
        -- Open first tab
        if Pages["Combat"] then
            Pages["Combat"].Page.Visible = true
            Pages["Combat"].Btn.BackgroundColor3 = CONFIG.Accent
            currentTab = "Combat"
        end
        StatusText.Text = "Zynix v5.0 – Rage ready"
    else
        KeyInput.Text = ""
        KeyInput.PlaceholderText = "INCORRECT KEY"
        task.wait(1)
        KeyInput.PlaceholderText = "Enter Key..."
    end
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == CONFIG.ToggleKey and State.Unlocked then
        Main.Visible = not Main.Visible
    end
end)

