-- FOV Circle drawing (aimbot)
local fovCircle
local function updateFOVCircle()
    if fovCircle and fovCircle.Remove then fovCircle:Remove() end
    if not features.Aimbot.FOVCircle or not Drawing then return end
    fovCircle = Drawing.new("Circle")
    fovCircle.Visible = true
    fovCircle.Color = Color3.fromRGB(0,140,255)
    fovCircle.Thickness = 1
    fovCircle.Radius = features.Aimbot.FOV
    fovCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
end

-- ESP Render loop
local espConnection
espConnection = RunService.RenderStepped:Connect(function()
    updateESP()
    updateHitboxVisuals()
    if features.Aimbot.FOVCircle then
        if not fovCircle or fovCircle.Radius ~= features.Aimbot.FOV then
            updateFOVCircle()
        end
    else
        if fovCircle then fovCircle:Remove(); fovCircle = nil end
    end
end)

-- Cleanup connections on script end
env.connections = env.connections or {}
table.insert(env.connections, espConnection)
table.insert(env.connections, aimbotConnection or function() end)
table.insert(env.connections, triggerbotConnection or function() end)
table.insert(env.connections, flyConnection or function() end)
table.insert(env.connections, noclipConnection or function() end)
table.insert(env.connections, bhopConnection or function() end)
table.insert(env.connections, antiAimConnection or function() end)
table.insert(env.connections, thirdPersonConnection or function() end)

LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    if features.Fly.Enabled then startFly() end
    if features.NoClip then startNoClip() end
    if features.AntiAim.Enabled then startAntiAim() end
end)

