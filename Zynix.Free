--// Tab System
local Pages = {}
local currentTab = nil

local function addTab(name, icon)
    local btn = Instance.new("TextButton", Sidebar)
    btn.Size = UDim2.new(0.9,0,0,36)
    btn.BackgroundColor3 = CONFIG.Background
    btn.Font = CONFIG.FontSmall
    btn.Text = icon.."  "..name
    btn.TextColor3 = CONFIG.Text
    btn.TextSize = 14
    btn.TextXAlignment = Enum.TextXAlignment.Left
    makeVisuals(btn, 6, 1, CONFIG.Outline)

    btn.MouseEnter:Connect(function()
        if currentTab ~= name then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = CONFIG.AccentDark}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if currentTab ~= name then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = CONFIG.Background}):Play()
        end
    end)

    local page = Instance.new("ScrollingFrame", Container)
    page.Size = UDim2.new(1, -10, 1, -10)
    page.Position = UDim2.new(0,5,0,5)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.ScrollBarThickness = 2
    page.ScrollBarImageColor3 = CONFIG.Accent
    page.ScrollingDirection = Enum.ScrollingDirection.Y
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.CanvasSize = UDim2.new(0,0,0,0)

    local layout = Instance.new("UIListLayout", page)
    layout.Padding = UDim.new(0, 8)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder

    btn.MouseButton1Click:Connect(function()
        if currentTab == name then return end
        for _, p in pairs(Pages) do
            p.Page.Visible = false
            p.Btn.BackgroundColor3 = CONFIG.Background
        end
        page.Visible = true
        btn.BackgroundColor3 = CONFIG.Accent
        currentTab = name
    end)

    Pages[name] = {Btn = btn, Page = page}
    return page
end

