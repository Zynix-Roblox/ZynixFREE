-- ==================== UI ENGINE ====================
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "Zynix_Master"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
ScreenGui.IgnoreGuiInset = true

local function createVisuals(obj, r, t, c)
    local corner = Instance.new("UICorner", obj)
    corner.CornerRadius = UDim.new(0, r)
    local stroke = Instance.new("UIStroke", obj)
    stroke.Thickness = t
    stroke.Color = c
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.LineJoinMode = Enum.LineJoinMode.Round
    return stroke
end

local function animateTitle(label)
    local gradient = Instance.new("UIGradient", label)
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, CONFIG.Accent),
        ColorSequenceKeypoint.new(0.5, Color3fromRGB(120, 0, 0)),
        ColorSequenceKeypoint.new(1, CONFIG.Accent)
    })
    gradient.Rotation = 0
    taskspawn(function()
        local rot = 0
        while label.Parent do
            rot = rot + 1.5
            gradient.Rotation = rot % 360
            RunService.RenderStepped:Wait()
        end
    end)
    local stroke = Instance.new("UIStroke", label)
    stroke.Color = CONFIG.Accent
    stroke.Thickness = 0
    stroke.Transparency = 1
    TweenService:Create(stroke, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Thickness = 2, Transparency = 0.5}):Play()
end

-- Smooth dragging function
local function drag(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

