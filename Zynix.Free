-- [Rest of the logic: Aimbot, Rage, Anti-Aim, ESP, Movement, etc. Identical to v5.0, but included here for completeness.]

local Camera = workspace.CurrentCamera
local FOVCircle = DrawingNew("Circle")
FOVCircle.Thickness = 1.5
FOVCircle.NumSides = 64
FOVCircle.Transparency = 1

-- Hitbox visuals
local function createHitboxCircle(color, transparency)
    local c = DrawingNew("Circle")
    c.Color = color
    c.Thickness = 0
    c.NumSides = 64
    c.Filled = true
    c.Transparency = transparency
    return c
end

local HitboxData = {}
local function getHitboxVisuals(player)
    if not HitboxData[player] then
        HitboxData[player] = {
            Outer = createHitboxCircle(Color3.fromRGB(0,140,255), 0.7),
            Inner = createHitboxCircle(Color3.fromRGB(255,255,255), 0.4),
        }
    end
    return HitboxData[player]
end
local function cleanHitboxData(player)
    local d = HitboxData[player]
    if d then d.Outer:Remove(); d.Inner:Remove(); HitboxData[player]=nil end
end

-- ESP cache
local ESP_Data = {}
local function getESP(p)
    if not ESP_Data[p] then
        local data = {
            Box = DrawingNew("Square"),
            BoxFill = DrawingNew("Square"),
            Name = DrawingNew("Text"),
            Dist = DrawingNew("Text"),
            Tracer = DrawingNew("Line"),
            HpBg = DrawingNew("Square"),
            HpBar = DrawingNew("Square"),
            Skel = {},
            Corner = {}
        }
        for i=1,14 do data.Skel[i] = DrawingNew("Line") end
        for i=1,8 do data.Corner[i] = DrawingNew("Line") end
        ESP_Data[p] = data
    end
    return ESP_Data[p]
end
local function cleanESP(p)
    local d = ESP_Data[p]
    if d then
        d.Box:Remove(); d.BoxFill:Remove(); d.Name:Remove(); d.Dist:Remove(); d.Tracer:Remove()
        d.HpBg:Remove(); d.HpBar:Remove()
        for _,l in ipairs(d.Skel) do l:Remove() end
        for _,l in ipairs(d.Corner) do l:Remove() end
        ESP_Data[p]=nil
    end
end

Players.PlayerRemoving:Connect(function(plr)
    cleanESP(plr); cleanHitboxData(plr)
end)

-- Bounding box
local function getBounds(char)
    local min = Vector3.new(math.huge,math.huge,math.huge)
    local max = Vector3.new(-math.huge,-math.huge,-math.huge)
    for _,p in ipairs(char:GetChildren()) do
        if p:IsA("BasePart") then
            local c = p.CFrame; local s = p.Size*0.5
            for x=-1,1,2 do for y=-1,1,2 do for z=-1,1,2 do
                local wp = c * Vector3.new(x*s.X, y*s.Y, z*s.Z)
                min = Vector3.new(math.min(min.X,wp.X), math.min(min.Y,wp.Y), math.min(min.Z,wp.Z))
                max = Vector3.new(math.max(max.X,wp.X), math.max(max.Y,wp.Y), math.max(max.Z,wp.Z))
            end end end
        end
    end
    return min,max
end

-- Skeleton connections
local R15 = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"}
}
local R6 = {{"Head","Torso"},{"Torso","Left Arm"},{"Torso","Right Arm"},{"Torso","Left Leg"},{"Torso","Right Leg"}}

local function getScreenRadius(cf, size)
    local center = Camera:WorldToViewportPoint(cf.Position)
    local maxDist = 0; local half = size*0.5
    for x=-1,1,2 do for y=-1,1,2 do for z=-1,1,2 do
        local wp = cf * Vector3.new(x*half.X, y*half.Y, z*half.Z)
        local sp, vis = Camera:WorldToViewportPoint(wp)
        if vis then
            local d = (Vector2.new(sp.X,sp.Y)-Vector2.new(center.X,center.Y)).Magnitude
            if d>maxDist then maxDist=d end
        end
    end end end
    return maxDist
end

-- Anti-aim
local antiAimStart = 0
local function getAntiAimYaw()
    local t = tick()
    if State.AntiAimType == "Jitter" then
        return (t*500 % 360 > 180) and 45 or -45
    elseif State.AntiAimType == "Spin" then
        return (t*300) % 360
    elseif State.AntiAimType == "Random" then
        if t - antiAimStart > 0.2 then
            antiAimStart = t
            return math.random(-90,90)
        end
    end
    return 0
end

-- Main loop
local lastTrigger = 0
local lastSwitch = 0
local currentRageTarget = nil
local flyBV = nil
local afkLast = tick()

RunService.RenderStepped:Connect(function(dt)
    if not State.Unlocked then return end

    -- Anti-AFK
    if State.AntiAFK and tick()-afkLast > 10 then mousemoverel(0,0); afkLast=tick() end

    Camera.FieldOfView = State.StretchedFOV

    if State.ThirdPerson then
        LocalPlayer.CameraMinZoomDistance = State.ThirdPersonDist
        LocalPlayer.CameraMaxZoomDistance = State.ThirdPersonDist+5
    else
        LocalPlayer.CameraMinZoomDistance = 0.5
        LocalPlayer.CameraMaxZoomDistance = 20
    end

    Workspace.Gravity = State.Gravity

    local mouseLoc = UserInputService:GetMouseLocation()
    local streamer = State.StreamerMode

    FOVCircle.Visible = (not streamer) and State.ShowFOV
    if State.ShowFOV and not streamer then
        FOVCircle.Position = mouseLoc
        FOVCircle.Radius = State.AimbotFOV
        FOVCircle.Color = State.RainbowFOV and Color3.fromHSV(tick()%5/5,1,1) or CONFIG.Accent
    end

    -- Rage target selection
    if State.RageMode and State.Aimbot then
        local targets = {}
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
                local char = plr.Character
                local root = char:FindFirstChild("HumanoidRootPart")
                local part = char:FindFirstChild(State.AimbotTarget) or root
                if root and part then
                    local pos,vis = Camera:WorldToViewportPoint(part.Position)
                    if vis then
                        local sd = (Vector2.new(pos.X,pos.Y)-mouseLoc).Magnitude
                        if sd <= State.RageFOV then
                            local teamOk = not State.AimbotTeam or plr.Team ~= LocalPlayer.Team
                            local wallOk = not State.AimbotWall or #Camera:GetPartsObscuringTarget({part.Position}, {LocalPlayer.Character, char})==0
                            if teamOk and wallOk then
                                local dist = (root.Position - (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position or root.Position)).Magnitude
                                table.insert(targets, {player=plr, screenDist=sd, distance=dist, health=char.Humanoid.Health})
                            end
                        end
                    end
                end
            end
        end
        if #targets>0 then
            if State.TargetPriority=="Crosshair" then table.sort(targets,function(a,b)return a.screenDist<b.screenDist end)
            elseif State.TargetPriority=="Distance" then table.sort(targets,function(a,b)return a.distance<b.distance end)
            else table.sort(targets,function(a,b)return a.health<b.health end) end
            local best = targets[1].player
            if best ~= currentRageTarget then
                local now = tick()*1000
                if now - lastSwitch >= State.TargetSwitchDelay then
                    currentRageTarget = best
                    lastSwitch = now
                end
            end
        else
            currentRageTarget = nil
        end
    else
        local closest, minDist = nil, State.AimbotFOV
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
                local char = plr.Character
                local root = char:FindFirstChild("HumanoidRootPart")
                local part = char:FindFirstChild(State.AimbotTarget) or root
                if root and part then
                    local pos,vis = Camera:WorldToViewportPoint(part.Position)
                    if vis then
                        local dist = (Vector2.new(pos.X,pos.Y)-mouseLoc).Magnitude
                        if dist<minDist and (not State.AimbotTeam or plr.Team~=LocalPlayer.Team) and (not State.AimbotWall or #Camera:GetPartsObscuringTarget({part.Position},{LocalPlayer.Character,char})==0) then
                            minDist=dist; closest=plr
                        end
                    end
                end
            end
        end
        currentRageTarget = closest
    end

    -- Aimbot execution
    local aimActive = State.Aimbot and (
        (State.RageMode) or
        (not State.RageMode and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2))
    )
    if aimActive and currentRageTarget then
        local char = currentRageTarget.Character
        local part = char:FindFirstChild(State.AimbotTarget) or char:FindFirstChild("HumanoidRootPart")
        if part then
            local pred = part.Position
            if State.AimbotPrediction>0 and part.Velocity then
                pred = pred + part.Velocity*(State.AimbotPrediction/10)*State.PredictionMultiplier
            end
            local pos = Camera:WorldToViewportPoint(pred)
            local smooth = State.InstantLock and 1 or State.AimbotSmooth
            mousemoverel((pos.X-mouseLoc.X)/smooth, (pos.Y-mouseLoc.Y)/smooth)
        end
        if State.AutoFire and State.RageMode then
            local now = tick()
            if now - lastTrigger >= State.TriggerbotDelay/1000 then
                mouse1click(); lastTrigger = now
            end
        end
        if State.AutoStop and State.RageMode and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = 0
        end
    else
        if State.AutoStop and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = State.Speed
        end
    end

    -- Triggerbot (non-rage)
    if State.Triggerbot and not State.RageMode then
        local canFire = State.TriggerbotHoldMouse and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or true
        if canFire then
            local now = tick()
            if now - lastTrigger >= State.TriggerbotDelay/1000 then
                local targ = LocalPlayer:GetMouse().Target
                if targ and targ.Parent and targ.Parent:FindFirstChild("Humanoid") then
                    local plr = Players:GetPlayerFromCharacter(targ.Parent)
                    if plr and plr~=LocalPlayer and (not State.AimbotTeam or plr.Team~=LocalPlayer.Team) then
                        mouse1click(); lastTrigger = now
                    end
                end
            end
        end
    end

    -- Hitbox Expander (other players)
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local root = plr.Character.HumanoidRootPart
            local vis = getHitboxVisuals(plr)
            if not vis.origSize then
                vis.origSize = root.Size
                vis.origCollide = root.CanCollide
            end
            local orig = vis.origSize
            local expand = State.HitboxExpander and State.HitboxExpandSize or 0
            local targetSize = orig + Vector3.new(expand,expand,expand)
            root.Size = root.Size:Lerp(targetSize, math.min(dt*12,1))
            local expanded = (root.Size - orig).Magnitude > 0.01
            if expanded then root.CanCollide = false else root.CanCollide = vis.origCollide end
            local showVis = expanded and State.HitboxVisuals and not streamer
            vis.Outer.Visible = showVis; vis.Inner.Visible = showVis
            if showVis then
                local sp, onScreen = Camera:WorldToViewportPoint(root.Position)
                if onScreen then
                    vis.Outer.Position = Vector2.new(sp.X,sp.Y)
                    vis.Outer.Radius = getScreenRadius(root.CFrame, targetSize)
                    vis.Inner.Position = Vector2.new(sp.X,sp.Y)
                    vis.Inner.Radius = getScreenRadius(root.CFrame, orig)
                else vis.Outer.Visible=false; vis.Inner.Visible=false end
            end
        end
    end

    -- ESP Loop
    if streamer then
        for _,plr in ipairs(Players:GetPlayers()) do
            local esp = ESP_Data[plr]
            if esp then
                esp.Box.Visible=false; esp.BoxFill.Visible=false; esp.Name.Visible=false; esp.Dist.Visible=false; esp.Tracer.Visible=false
                esp.HpBg.Visible=false; esp.HpBar.Visible=false
                for _,l in ipairs(esp.Skel) do l.Visible=false end
                for _,l in ipairs(esp.Corner) do l.Visible=false end
            end
        end
    else
        for _,plr in ipairs(Players:GetPlayers()) do
            local esp = getESP(plr)
            if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
                local char = plr.Character
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    local color
                    if State.ESPTeamColors then
                        color = (plr.Team == LocalPlayer.Team) and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)
                    elseif State.ESPRainbow then
                        color = Color3.fromHSV(tick()%5/5,1,1)
                    else
                        color = CONFIG.Accent
                    end

                    local minB,maxB = getBounds(char)
                    local corners = {
                        Vector3.new(minB.X,minB.Y,minB.Z), Vector3.new(minB.X,minB.Y,maxB.Z),
                        Vector3.new(minB.X,maxB.Y,minB.Z), Vector3.new(minB.X,maxB.Y,maxB.Z),
                        Vector3.new(maxB.X,minB.Y,minB.Z), Vector3.new(maxB.X,minB.Y,maxB.Z),
                        Vector3.new(maxB.X,maxB.Y,minB.Z), Vector3.new(maxB.X,maxB.Y,maxB.Z)
                    }
                    local minX,minY,maxX,maxY = math.huge,math.huge,-math.huge,-math.huge
                    local anyOn = false
                    for _,c in ipairs(corners) do
                        local sp,on = Camera:WorldToViewportPoint(c)
                        if on then anyOn=true; if sp.X<minX then minX=sp.X end; if sp.Y<minY then minY=sp.Y end; if sp.X>maxX then maxX=sp.X end; if sp.Y>maxY then maxY=sp.Y end end
                    end

                    if anyOn then
                        local w = maxX-minX; local h = maxY-minY; local x = minX; local y = minY
                        if State.ESPBox then
                            if State.ESPBoxType=="2D" then
                                esp.Box.Visible=true; esp.Box.Position=Vector2.new(x,y); esp.Box.Size=Vector2.new(w,h)
                                esp.Box.Color=color; esp.Box.Thickness=1.5
                                for i=1,8 do esp.Corner[i].Visible=false end
                            else
                                esp.Box.Visible=false
                                local len = w*0.25
                                esp.Corner[1].Visible=true; esp.Corner[1].From=Vector2.new(x,y); esp.Corner[1].To=Vector2.new(x+len,y)
                                esp.Corner[2].Visible=true; esp.Corner[2].From=Vector2.new(x,y); esp.Corner[2].To=Vector2.new(x,y+len)
                                esp.Corner[3].Visible=true; esp.Corner[3].From=Vector2.new(maxX,y); esp.Corner[3].To=Vector2.new(maxX-len,y)
                                esp.Corner[4].Visible=true; esp.Corner[4].From=Vector2.new(maxX,y); esp.Corner[4].To=Vector2.new(maxX,y+len)
                                esp.Corner[5].Visible=true; esp.Corner[5].From=Vector2.new(x,maxY); esp.Corner[5].To=Vector2.new(x+len,maxY)
                                esp.Corner[6].Visible=true; esp.Corner[6].From=Vector2.new(x,maxY); esp.Corner[6].To=Vector2.new(x,maxY-len)
                                esp.Corner[7].Visible=true; esp.Corner[7].From=Vector2.new(maxX,maxY); esp.Corner[7].To=Vector2.new(maxX-len,maxY)
                                esp.Corner[8].Visible=true; esp.Corner[8].From=Vector2.new(maxX,maxY); esp.Corner[8].To=Vector2.new(maxX,maxY-len)
                                for _,l in ipairs(esp.Corner) do l.Color=color; l.Thickness=1.5 end
                            end
                            if State.ESPFill then
                                esp.BoxFill.Visible=true; esp.BoxFill.Position=Vector2.new(x,y); esp.BoxFill.Size=Vector2.new(w,h)
                                esp.BoxFill.Color=color; esp.BoxFill.Thickness=0; esp.BoxFill.Filled=true; esp.BoxFill.Transparency=0.7
                            else esp.BoxFill.Visible=false end
                        else
                            esp.Box.Visible=false; esp.BoxFill.Visible=false
                            for i=1,8 do esp.Corner[i].Visible=false end
                        end
                        if State.ESPName then
                            esp.Name.Visible=true; esp.Name.Text=plr.Name; esp.Name.Size=15; esp.Name.Center=true; esp.Name.Outline=true
                            esp.Name.Position=Vector2.new((x+maxX)/2, y-18); esp.Name.Color=CONFIG.Text
                        else esp.Name.Visible=false end
                        if State.ESPDistance then
                            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                            local dist = myRoot and (root.Position - myRoot.Position).Magnitude or 0
                            esp.Dist.Visible=true; esp.Dist.Text=string.format("%.0f m",dist); esp.Dist.Size=13; esp.Dist.Center=true; esp.Dist.Outline=true
                            esp.Dist.Position=Vector2.new((x+maxX)/2, y+h+5); esp.Dist.Color=CONFIG.Text
                        else esp.Dist.Visible=false end
                        if State.ESPHealthBar then
                            local hp = char.Humanoid.Health / char.Humanoid.MaxHealth
                            local bw=3; local bh=h; local bx=x-6; local by=y
                            esp.HpBg.Visible=true; esp.HpBg.Size=Vector2.new(bw,bh); esp.HpBg.Position=Vector2.new(bx,by)
                            esp.HpBg.Color=Color3.fromRGB(40,40,40); esp.HpBg.Filled=true
                            esp.HpBar.Visible=true; esp.HpBar.Size=Vector2.new(bw,bh*hp); esp.HpBar.Position=Vector2.new(bx,by+bh*(1-hp))
                            esp.HpBar.Color=Color3.fromRGB(0,255,0):Lerp(Color3.fromRGB(255,0,0),1-hp); esp.HpBar.Filled=true
                        else esp.HpBg.Visible=false; esp.HpBar.Visible=false end
                        if State.ESPTracer then
                            esp.Tracer.Visible=true; esp.Tracer.From=Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                            esp.Tracer.To=Vector2.new((x+maxX)/2, maxY); esp.Tracer.Color=color; esp.Tracer.Thickness=1.2
                        else esp.Tracer.Visible=false end
                        if State.ESPSkeleton then
                            local isR15 = char:FindFirstChild("LowerTorso") ~= nil
                            local conns = isR15 and R15 or R6
                            for i,conn in ipairs(conns) do
                                local a = char:FindFirstChild(conn[1]); local b = char:FindFirstChild(conn[2])
                                local line = esp.Skel[i]
                                if a and b then
                                    local pA = Camera:WorldToViewportPoint(a.Position); local pB = Camera:WorldToViewportPoint(b.Position)
                                    line.Visible=true; line.From=Vector2.new(pA.X,pA.Y); line.To=Vector2.new(pB.X,pB.Y); line.Color=color; line.Thickness=1.2
                                else line.Visible=false end
                            end
                            for i=#conns+1, #esp.Skel do esp.Skel[i].Visible=false end
                        else for _,l in ipairs(esp.Skel) do l.Visible=false end end
                    else
                        esp.Box.Visible=false; esp.BoxFill.Visible=false; esp.Name.Visible=false; esp.Dist.Visible=false; esp.Tracer.Visible=false
                        esp.HpBg.Visible=false; esp.HpBar.Visible=false
                        for _,l in ipairs(esp.Skel) do l.Visible=false end
                        for _,l in ipairs(esp.Corner) do l.Visible=false end
                    end
                end
            else
                esp.Box.Visible=false; esp.BoxFill.Visible=false; esp.Name.Visible=false; esp.Dist.Visible=false; esp.Tracer.Visible=false
                esp.HpBg.Visible=false; esp.HpBar.Visible=false
                for _,l in ipairs(esp.Skel) do l.Visible=false end
                for _,l in ipairs(esp.Corner) do l.Visible=false end
            end
        end
    end

    -- Anti-Aim
    if State.AntiAim and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local root = LocalPlayer.Character.HumanoidRootPart
        root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(getAntiAimYaw()), 0)
    end

    -- Movement
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local hum = LocalPlayer.Character.Humanoid
        local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not (State.AutoStop and State.RageMode) then
            hum.WalkSpeed = State.Speed
        end
        if State.NoJumpCooldown and UserInputService:IsKeyDown(Enum.KeyCode.Space) then hum.Jump = true end
        if State.Fly and root then
            if not flyBV or flyBV.Parent ~= root then
                if flyBV then flyBV:Destroy() end
                flyBV = Instance.new("BodyVelocity")
                flyBV.MaxForce = Vector3.new(1e5,1e5,1e5)
                flyBV.Parent = root
                hum.PlatformStand = true
            end
            local mv = Vector3.new(0,0,0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv += Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv -= Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv -= Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv += Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then mv += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then mv -= Vector3.new(0,1,0) end
            flyBV.Velocity = mv * State.FlySpeed
        else
            if flyBV then flyBV:Destroy(); flyBV=nil end
            if hum.PlatformStand then hum.PlatformStand=false end
        end
        if State.Bhop and hum.FloorMaterial ~= Enum.Material.Air then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        if State.Spin and root and not State.AntiAim then root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(25*dt*60), 0) end
    end
end)

-- NoClip/Fullbright
RunService.Stepped:Connect(function()
    if State.Unlocked and State.NoClip and LocalPlayer.Character then
        for _,v in ipairs(LocalPlayer.Character:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide=false end end
    end
    if State.Unlocked and State.Fullbright then
        Lighting.Brightness=2; Lighting.ClockTime=14; Lighting.GlobalShadows=false
    else
        if not State.Fullbright then
            Lighting.Brightness=1; Lighting.ClockTime=12; Lighting.GlobalShadows=true
        end
    end
end)

-- Cleanup
local function cleanup()
    for p,_ in pairs(ESP_Data) do cleanESP(p) end
    for p,_ in pairs(HitboxData) do cleanHitboxData(p) end
    if flyBV then flyBV:Destroy() end
    ScreenGui:Destroy()
end

print("Zynix v5.0.2 loaded successfully! Rage ready.")

end) -- end of pcall

-- Catch errors
if not success then
    warn("Zynix critical error: " .. tostring(err))
    -- Fallback: create a simple notification
    local screen = Instance.new("ScreenGui", game:GetService("CoreGui"))
    local msg = Instance.new("TextLabel", screen)
    msg.Size = UDim2.new(0, 300, 0, 50)
    msg.Position = UDim2.new(0.5, -150, 0.5, -25)
    msg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    msg.TextColor3 = Color3.fromRGB(255, 100, 100)
    msg.Text = "Zynix failed to load. Check console (F9)."
    msg.Font = Enum.Font.SourceSansBold
    msg.TextSize = 16
end
