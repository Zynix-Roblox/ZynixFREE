--// Master Logic ---------------------------------------------------------------
local Camera = workspace.CurrentCamera
local FOVCircle = DrawingNew("Circle")
FOVCircle.Thickness = 1.5
FOVCircle.NumSides = 64
FOVCircle.Transparency = 1

-- Hitbox Visuals
local function createHitboxCircle(color, transparency, filled, thickness)
    local c = DrawingNew("Circle")
    c.Color = color
    c.Thickness = thickness
    c.NumSides = 64
    c.Filled = filled
    c.Transparency = transparency
    return c
end

local HitboxData = {}
local function getHitboxVisuals(player)
    if not HitboxData[player] then
        HitboxData[player] = {
            Outer = createHitboxCircle(Color3.fromRGB(0, 140, 255), 0.5, false, 2),
            Inner = createHitboxCircle(Color3.fromRGB(255, 255, 255), 0.6, true, 0),
        }
    end
    return HitboxData[player]
end
local function cleanHitboxData(player)
    local d = HitboxData[player]
    if d then d.Outer:Remove(); d.Inner:Remove(); HitboxData[player] = nil end
end

-- ESP Cache
local ESP_Data = {}
local function getESP(p)
    if not ESP_Data[p] then
        local data = {
            Box = DrawingNew("Square"), BoxFill = DrawingNew("Square"),
            Name = DrawingNew("Text"), Dist = DrawingNew("Text"),
            Tracer = DrawingNew("Line"), HpBg = DrawingNew("Square"), HpBar = DrawingNew("Square"),
            Skel = {}, Corner = {}
        }
        for i=1,14 do data.Skel[i] = DrawingNew("Line") end
        for i=1,8 do data.Corner[i] = DrawingNew("Line") end
        ESP_Data[p] = data
    end
    return ESP_Data[p]
end
local function cleanESP(p)
    local d = ESP_Data[p]
    if d then
        d.Box:Remove(); d.BoxFill:Remove(); d.Name:Remove(); d.Dist:Remove(); d.Tracer:Remove()
        d.HpBg:Remove(); d.HpBar:Remove()
        for _,l in ipairs(d.Skel) do l:Remove() end
        for _,l in ipairs(d.Corner) do l:Remove() end
        ESP_Data[p] = nil
    end
end

Players.PlayerRemoving:Connect(function(plr) cleanESP(plr); cleanHitboxData(plr) end)

-- Utility: get character bounding box
local function getBounds(char)
    local min = Vec3(math.huge, math.huge, math.huge)
    local max = Vec3(-math.huge, -math.huge, -math.huge)
    for _,p in ipairs(char:GetChildren()) do
        if p:IsA("BasePart") then
            local c = p.CFrame; local s = p.Size*0.5
            for x=-1,1,2 do for y=-1,1,2 do for z=-1,1,2 do
                local wp = c * Vec3(x*s.X, y*s.Y, z*s.Z)
                min = Vec3(math.min(min.X,wp.X), math.min(min.Y,wp.Y), math.min(min.Z,wp.Z))
                max = Vec3(math.max(max.X,wp.X), math.max(max.Y,wp.Y), math.max(max.Z,wp.Z))
            end end end
        end
    end
    return min, max
end

-- Skeleton connections
local R15 = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"}
}
local R6 = {{"Head","Torso"},{"Torso","Left Arm"},{"Torso","Right Arm"},{"Torso","Left Leg"},{"Torso","Right Leg"}}

-- Screen radius from world size (used for hitbox circles)
local function getScreenRadius(cf, size)
    local center = Camera:WorldToViewportPoint(cf.Position)
    local maxDist = 0; local half = size*0.5
    for x=-1,1,2 do for y=-1,1,2 do for z=-1,1,2 do
        local wp = cf * Vec3(x*half.X, y*half.Y, z*half.Z)
        local sp, vis = Camera:WorldToViewportPoint(wp)
        if vis then
            local d = (Vec2(sp.X,sp.Y)-Vec2(center.X,center.Y)).Magnitude
            if d > maxDist then maxDist = d end
        end
    end end end
    return maxDist
end

-- Hitsound
local hitSoundId = {
    Bell = "rbxassetid://6040293276",
    Ding = "rbxassetid://6040293276",
    Pop = "rbxassetid://6040293276",
    Custom = "rbxassetid://6040293276"
}
local previousHealth = {}
local function playHitsound()
    if not State.HitsoundEnabled then return end
    local sound = Instance.new("Sound")
    sound.SoundId = hitSoundId[State.HitsoundType] or hitSoundId.Bell
    sound.Volume = 0.5
    sound.Parent = workspace.CurrentCamera or workspace
    sound:Play()
    Debris:AddItem(sound, 1)
end

-- Anti-Aim Engine
local antiAimState = {
    lastSwitch = 0,
    currentJitter = 45,
    currentSpin = 0,
}
local function getAntiAimYaw()
    if not State.AntiAim then return 0 end
    local speed = State.AntiAimSpeed
    local style = State.AntiAimStyle
    local t = tick()
    if style == "Jitter" then
        if t - antiAimState.lastSwitch > (1 / math.max(speed/100, 0.05)) then
            antiAimState.lastSwitch = t
            antiAimState.currentJitter = -antiAimState.currentJitter
        end
        return rad(antiAimState.currentJitter)
    elseif style == "Spin" then
        antiAimState.currentSpin = (antiAimState.currentSpin + speed * 0.1) % 360
        return rad(antiAimState.currentSpin)
    elseif style == "Random" then
        if t - antiAimState.lastSwitch > (1 / math.max(speed/100, 0.1)) then
            antiAimState.lastSwitch = t
            antiAimState.currentJitter = rand(-180, 180)
        end
        return rad(antiAimState.currentJitter)
    elseif style == "Custom" then
        return rad(State.AntiAimCustomAngle)
    end
    return 0
end

--// Main Loop (RenderStepped) ------------------------------------------------
local lastTrigger = 0
local flyBV = nil
local afkLast = 0

RunService.RenderStepped:Connect(function(dt)
    if not State.Unlocked then return end

    -- Anti-AFK
    if State.AntiAFK and (tick() - afkLast) > 10 then
        if mousemoverel then mousemoverel(0,0) end
        afkLast = tick()
    end

    -- Camera FOV & Third Person
    Camera.FieldOfView = State.FOVChanger
    if State.ThirdPerson then
        LocalPlayer.CameraMode = Enum.CameraMode.Classic
        LocalPlayer.CameraMinZoomDistance = State.ThirdPersonDist
        LocalPlayer.CameraMaxZoomDistance = State.ThirdPersonDist + 1
    else
        LocalPlayer.CameraMode = Enum.CameraMode.Classic
        LocalPlayer.CameraMinZoomDistance = 0.5
        LocalPlayer.CameraMaxZoomDistance = 20
    end

    -- Gravity
    Workspace.Gravity = State.Gravity

    local mouseLoc = UserInputService:GetMouseLocation()
    local streamer = State.StreamerMode

    -- FOV Circle
    FOVCircle.Visible = (not streamer) and State.ShowFOV
    if State.ShowFOV and not streamer then
        FOVCircle.Position = mouseLoc
        FOVCircle.Radius = State.AimbotFOV
        FOVCircle.Color = State.RainbowFOV and Color3.fromHSV(tick()%5/5,1,1) or CONFIG.Accent
    end

    -- Aimbot target selection
    local target = nil
    if State.Aimbot and mousemoverel then
        local closest, minDist = nil, State.AimbotFOV
        local myChar = LocalPlayer.Character
        if myChar then
            for _,plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
                    local char = plr.Character
                    local root = char:FindFirstChild("HumanoidRootPart")
                    local part = char:FindFirstChild(State.AimbotTarget) or root
                    if root and part then
                        local pos, vis = Camera:WorldToViewportPoint(part.Position)
                        if vis then
                            local dist = (Vec2(pos.X, pos.Y) - mouseLoc).Magnitude
                            if dist < minDist then
                                local teamOk = not State.AimbotTeam or plr.Team ~= LocalPlayer.Team
                                local wallOk = not State.AimbotWall or #Camera:GetPartsObscuringTarget({part.Position}, {myChar, char}) == 0
                                if teamOk and wallOk then
                                    minDist = dist
                                    closest = {player = plr, part = part}
                                end
                            end
                        end
                    end
                end
            end
        end
        target = closest
    end

    -- Aimbot Execution (hold right mouse button)
    if State.Aimbot and target and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local part = target.part
        local predictedPos = part.Position
        if State.AimbotPrediction > 0 and part.Velocity then
            predictedPos = predictedPos + part.Velocity * (State.AimbotPrediction / 10)
        end
        local pos = Camera:WorldToViewportPoint(predictedPos)
        if pos then
            mousemoverel((pos.X - mouseLoc.X) / State.AimbotSmooth, (pos.Y - mouseLoc.Y) / State.AimbotSmooth)
        end
    end

    -- Triggerbot
    if State.Triggerbot and mouse1click then
        local canFire = State.TriggerbotHoldMouse and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or true
        if canFire then
            local now = tick()
            if now - lastTrigger >= State.TriggerbotDelay / 1000 then
                local targ = LocalPlayer:GetMouse().Target
                if targ and targ.Parent and targ.Parent:FindFirstChild("Humanoid") then
                    local plr = Players:GetPlayerFromCharacter(targ.Parent)
                    if plr and plr ~= LocalPlayer then
                        if not State.AimbotTeam or plr.Team ~= LocalPlayer.Team then
                            mouse1click()
                            lastTrigger = now
                        end
                    end
                end
            end
        end
    end

    -- Hitsound detection
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Humanoid") then
            local hum = plr.Character.Humanoid
            local cur = hum.Health
            if previousHealth[plr] and cur < previousHealth[plr] then
                playHitsound()
            end
            previousHealth[plr] = cur
        end
    end

    -- Hitbox Expander (other players)
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local root = plr.Character.HumanoidRootPart
            local vis = getHitboxVisuals(plr)
            if not vis.origSize then
                vis.origSize = root.Size
                vis.origCollide = root.CanCollide
            end
            local orig = vis.origSize
            local expand = State.HitboxExpander and State.HitboxExpandSize or 0
            local targetSize = orig + Vec3(expand, expand, expand)
            root.Size = root.Size:Lerp(targetSize, math.min(dt*12, 1))
            local expanded = (root.Size - orig).Magnitude > 0.01
            if expanded then root.CanCollide = false else root.CanCollide = vis.origCollide end
            local showVis = expanded and State.HitboxVisuals and not streamer
            vis.Outer.Visible = showVis; vis.Inner.Visible = showVis
            if showVis then
                local sp, onScreen = Camera:WorldToViewportPoint(root.Position)
                if onScreen then
                    vis.Outer.Position = Vec2(sp.X, sp.Y); vis.Outer.Radius = getScreenRadius(root.CFrame, targetSize)
                    vis.Inner.Position = Vec2(sp.X, sp.Y); vis.Inner.Radius = getScreenRadius(root.CFrame, orig)
                else
                    vis.Outer.Visible = false; vis.Inner.Visible = false
                end
            end
        end
    end

    -- ESP Loop
    if streamer then
        for _,plr in ipairs(Players:GetPlayers()) do
            local esp = ESP_Data[plr]
            if esp then
                for _,v in pairs(esp) do
                    if type(v) == "table" then for _,l in ipairs(v) do l.Visible = false end
                    else v.Visible = false end
                end
            end
        end
    else
        for _,plr in ipairs(Players:GetPlayers()) do
            local esp = getESP(plr)
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
                local char = plr.Character
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    local color
                    if State.ESPTeamColors then
                        color = (plr.Team == LocalPlayer.Team) and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)
                    elseif State.ESPRainbow then
                        color = Color3.fromHSV(tick()%5/5,1,1)
                    else
                        color = CONFIG.Accent
                    end

                    local minB, maxB = getBounds(char)
                    local corners = {
                        Vec3(minB.X,minB.Y,minB.Z), Vec3(minB.X,minB.Y,maxB.Z),
                        Vec3(minB.X,maxB.Y,minB.Z), Vec3(minB.X,maxB.Y,maxB.Z),
                        Vec3(maxB.X,minB.Y,minB.Z), Vec3(maxB.X,minB.Y,maxB.Z),
                        Vec3(maxB.X,maxB.Y,minB.Z), Vec3(maxB.X,maxB.Y,maxB.Z)
                    }
                    local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
                    local anyOn = false
                    for _,c in ipairs(corners) do
                        local sp, on = Camera:WorldToViewportPoint(c)
                        if on then
                            anyOn = true
                            if sp.X < minX then minX = sp.X end
                            if sp.Y < minY then minY = sp.Y end
                            if sp.X > maxX then maxX = sp.X end
                            if sp.Y > maxY then maxY = sp.Y end
                        end
                    end

                    if anyOn then
                        local w = maxX - minX; local h = maxY - minY; local x = minX; local y = minY
                        if State.ESPBox then
                            if State.ESPBoxType == "2D" then
                                esp.Box.Visible = true
                                esp.Box.Position = Vec2(x, y)
                                esp.Box.Size = Vec2(w, h)
                                esp.Box.Color = color; esp.Box.Thickness = 1.5
                                for i=1,8 do esp.Corner[i].Visible = false end
                            else
                                esp.Box.Visible = false
                                local len = w * 0.25
                                local lines = {
                                    {x, y, x+len, y}, {x, y, x, y+len},
                                    {maxX, y, maxX-len, y}, {maxX, y, maxX, y+len},
                                    {x, maxY, x+len, maxY}, {x, maxY, x, maxY-len},
                                    {maxX, maxY, maxX-len, maxY}, {maxX, maxY, maxX, maxY-len}
                                }
                                for i, line in ipairs(lines) do
                                    esp.Corner[i].Visible = true
                                    esp.Corner[i].From = Vec2(line[1], line[2])
                                    esp.Corner[i].To = Vec2(line[3], line[4])
                                    esp.Corner[i].Color = color; esp.Corner[i].Thickness = 1.5
                                end
                            end
                            if State.ESPFill then
                                esp.BoxFill.Visible = true
                                esp.BoxFill.Position = Vec2(x, y); esp.BoxFill.Size = Vec2(w, h)
                                esp.BoxFill.Color = color; esp.BoxFill.Thickness = 0
                                esp.BoxFill.Filled = true; esp.BoxFill.Transparency = 0.7
                            else
                                esp.BoxFill.Visible = false
                            end
                        else
                            esp.Box.Visible = false; esp.BoxFill.Visible = false
                            for i=1,8 do esp.Corner[i].Visible = false end
                        end

                        if State.ESPName then
                            esp.Name.Visible = true; esp.Name.Text = plr.Name; esp.Name.Size = 15
                            esp.Name.Center = true; esp.Name.Outline = true
                            esp.Name.Position = Vec2((x+maxX)/2, y-18); esp.Name.Color = CONFIG.Text
                        else esp.Name.Visible = false end

                        if State.ESPDistance then
                            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                            local dist = myRoot and (root.Position - myRoot.Position).Magnitude or 0
                            esp.Dist.Visible = true; esp.Dist.Text = string.format("%.0f m", dist)
                            esp.Dist.Size = 13; esp.Dist.Center = true; esp.Dist.Outline = true
                            esp.Dist.Position = Vec2((x+maxX)/2, y+h+5); esp.Dist.Color = CONFIG.Text
                        else esp.Dist.Visible = false end

                        if State.ESPHealthBar then
                            local hp = char.Humanoid.Health / char.Humanoid.MaxHealth
                            local bw = 3; local bh = h; local bx = x-6; local by = y
                            esp.HpBg.Visible = true; esp.HpBg.Size = Vec2(bw, bh)
                            esp.HpBg.Position = Vec2(bx, by); esp.HpBg.Color = Color3.fromRGB(40,40,40); esp.HpBg.Filled = true
                            esp.HpBar.Visible = true; esp.HpBar.Size = Vec2(bw, bh*hp)
                            esp.HpBar.Position = Vec2(bx, by + bh*(1-hp))
                            esp.HpBar.Color = Color3.fromRGB(0,255,0):Lerp(Color3.fromRGB(255,0,0), 1-hp); esp.HpBar.Filled = true
                        else esp.HpBg.Visible = false; esp.HpBar.Visible = false end

                        if State.ESPTracer then
                            esp.Tracer.Visible = true
                            esp.Tracer.From = Vec2(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                            esp.Tracer.To = Vec2((x+maxX)/2, maxY)
                            esp.Tracer.Color = color; esp.Tracer.Thickness = 1.2
                        else esp.Tracer.Visible = false end

                        if State.ESPSkeleton then
                            local isR15 = char:FindFirstChild("LowerTorso") ~= nil
                            local conns = isR15 and R15 or R6
                            for i,conn in ipairs(conns) do
                                local a = char:FindFirstChild(conn[1]); local b = char:FindFirstChild(conn[2])
                                local line = esp.Skel[i]
                                if a and b then
                                    local pA = Camera:WorldToViewportPoint(a.Position); local pB = Camera:WorldToViewportPoint(b.Position)
                                    line.Visible = true; line.From = Vec2(pA.X, pA.Y); line.To = Vec2(pB.X, pB.Y)
                                    line.Color = color; line.Thickness = 1.2
                                else line.Visible = false end
                            end
                            for i=#conns+1, #esp.Skel do esp.Skel[i].Visible = false end
                        else for _,l in ipairs(esp.Skel) do l.Visible = false end end
                    else
                        for _,v in pairs(esp) do
                            if type(v)=="table" then for _,l in ipairs(v) do l.Visible = false end
                            else v.Visible = false end
                        end
                    end
                end
            else
                for _,v in pairs(esp) do
                    if type(v)=="table" then for _,l in ipairs(v) do l.Visible = false end
                    else v.Visible = false end
                end
            end
        end
    end

    -- Anti-Aim
    if State.AntiAim and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local root = LocalPlayer.Character.HumanoidRootPart
        local head = LocalPlayer.Character:FindFirstChild("Head")
        local yaw = getAntiAimYaw()
        -- Rotate body
        root.CFrame = CFrameNew(root.Position) * CFrameAngles(0, yaw, 0)
        -- Handle head according to mode
        if head then
            if State.AntiAimMode == "Body Only" then
                -- Keep head facing camera direction
                local camDir = Camera.CFrame.LookVector
                local camYaw = atan2(camDir.X, camDir.Z)
                head.CFrame = CFrameNew(head.Position) * CFrameAngles(0, camYaw, 0)
            else
                -- Full: head follows body rotation (implicitly, but we set it anyway)
                head.CFrame = CFrameNew(head.Position) * CFrameAngles(0, yaw, 0)
            end
        end
    end

    -- Movement
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local hum = LocalPlayer.Character.Humanoid
        local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        hum.WalkSpeed = State.Speed

        if State.NoJumpCooldown and UserInputService:IsKeyDown(Enum.KeyCode.Space) then hum.Jump = true end

        if State.Fly and root then
            if not flyBV or flyBV.Parent ~= root then
                if flyBV then flyBV:Destroy() end
                flyBV = Instance.new("BodyVelocity")
                flyBV.MaxForce = Vec3(1e5,1e5,1e5)
                flyBV.Parent = root
                hum.PlatformStand = true
            end
            local mv = Vec3(0,0,0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv += Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv -= Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv -= Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv += Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then mv += Vec3(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then mv -= Vec3(0,1,0) end
            flyBV.Velocity = mv * State.FlySpeed
        else
            if flyBV then flyBV:Destroy(); flyBV = nil end
            if hum.PlatformStand then hum.PlatformStand = false end
        end

        if State.Bhop and hum.FloorMaterial ~= Enum.Material.Air then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        if State.Spin and root then root.CFrame = root.CFrame * CFrameAngles(0, rad(25*dt*60), 0) end
    end
end)

--// NoClip and Fullbright (Stepped)
RunService.Stepped:Connect(function()
    if State.Unlocked and State.NoClip and LocalPlayer.Character then
        for _,v in ipairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
    if State.Unlocked then
        if State.Fullbright then
            Lighting.Brightness = 2
            Lighting.ClockTime = 14
            Lighting.GlobalShadows = false
        else
            Lighting.Brightness = 1
            Lighting.ClockTime = 12
            Lighting.GlobalShadows = true
        end
    end
end)

--// Cleanup
local function cleanup()
    for p,_ in pairs(ESP_Data) do cleanESP(p) end
    for p,_ in pairs(HitboxData) do cleanHitboxData(p) end
    if flyBV then flyBV:Destroy() end
    ScreenGui:Destroy()
end

print("Zynix FREE Loaded Successfully!")
