-- ==================== UI ENGINE ====================
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "Zynix_Master"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global

local function createVisuals(obj, r, t, c)
    local corner = Instance.new("UICorner", obj)
    corner.CornerRadius = UDim.new(0, r)
    local stroke = Instance.new("UIStroke", obj)
    stroke.Thickness = t
    stroke.Color = c
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return stroke
end

-- Particle effect on background
local function addParticles(parent)
    local particles = Instance.new("Frame", parent)
    particles.Size = UDim2.new(1,0,1,0)
    particles.BackgroundTransparency = 1
    particles.ZIndex = 0
    for _=1,20 do
        local dot = Instance.new("Frame", particles)
        dot.Size = UDim2.new(0,4,0,4)
        dot.BackgroundColor3 = CONFIG.AccentGlow
        dot.BackgroundTransparency = 0.8
        dot.BorderSizePixel = 0
        dot.Position = UDim2.new(math.random(),0, math.random(),0)
        dot.AnchorPoint = Vector2.new(0.5,0.5)
        Instance.new("UICorner", dot).CornerRadius = UDim.new(0,2)
        TweenService:Create(dot, TweenInfo.new(math.random(3,6), Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1, true), {
            Position = UDim2.new(math.random(),0, math.random(),0),
            Transparency = 0.95
        }):Play()
    end
end

local function animateTitle(label)
    local gradient = Instance.new("UIGradient", label)
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, CONFIG.AccentGlow),
        ColorSequenceKeypoint.new(0.5, CONFIG.AccentDark),
        ColorSequenceKeypoint.new(1, CONFIG.AccentGlow)
    })
    gradient.Rotation = 0
    spawn(function()
        local rot = 0
        while label.Parent do
            rot = rot + 1.5
            gradient.Rotation = rot % 360
            RunService.RenderStepped:Wait()
        end
    end)
    local stroke = Instance.new("UIStroke", label)
    stroke.Color = CONFIG.Accent
    stroke.Thickness = 0
    stroke.Transparency = 1
    TweenService:Create(stroke, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Thickness = 2, Transparency = 0.5}):Play()
end

local function drag(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

