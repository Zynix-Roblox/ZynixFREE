--[[
   Implement Features
--]]
local function getClosestPlayerToCursor()
    local closest = nil
    local minDist = math.huge
    local cameraPos = Camera.CFrame.Position
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char or not char:FindFirstChild("Head") then continue end
        if features.Aimbot.TeamCheck and player.Team == LocalPlayer.Team then continue end
        local head = char.Head
        local pos, onScreen = Camera:WorldToScreenPoint(head.Position)
        if not onScreen then continue end
        local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
        if dist < minDist then
            minDist = dist
            closest = {player = player, char = char, head = head, screenPos = Vector2.new(pos.X, pos.Y), dist = dist}
        end
    end
    return closest
end

local function aimbotWallCheck(targetPos)
    local ray = Ray.new(Camera.CFrame.Position, (targetPos - Camera.CFrame.Position).Unit * 1000)
    local hit, hitPos = Workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character}, false, true)
    if hit and hit:IsDescendantOf(Workspace) then
        local targetChar = features.Aimbot.TargetChar
        if targetChar and not hit:IsDescendantOf(targetChar) then
            return true
        end
    end
    return false
end

local aimbotConnection
local function startAimbot()
    if aimbotConnection then aimbotConnection:Disconnect() end
    aimbotConnection = RunService.RenderStepped:Connect(function(deltaTime)
        if not features.Aimbot.Enabled then return end
        local closest = nil
        if features.Aimbot.TargetPriority == "Distance" then
            local minDist = math.huge
            for _, player in pairs(Players:GetPlayers()) do
                if player == LocalPlayer then continue end
                local char = player.Character
                if not char or not char:FindFirstChild("Head") then continue end
                if features.Aimbot.TeamCheck and player.Team == LocalPlayer.Team then continue end
                local headPos = char.Head.Position
                local screenPos, onScreen = Camera:WorldToScreenPoint(headPos)
                if not onScreen then continue end
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                local effFov = features.Aimbot.FOV + (features.HitboxExpander.Enabled and features.HitboxExpander.Size or 0)
                if dist <= effFov then
                    if features.Aimbot.WallCheck and aimbotWallCheck(headPos) then continue end
                    if dist < minDist then
                        minDist = dist
                        closest = {char = char, head = char.Head, screenPos = Vector2.new(screenPos.X, screenPos.Y)}
                    end
                end
            end
        end
        if closest then
            local aimPos = closest.head.Position
            if features.Aimbot.Prediction > 0 then
                local root = closest.char:FindFirstChild("HumanoidRootPart")
                if root then
                    aimPos = aimPos + root.Velocity * features.Aimbot.Prediction
                end
            end
            local aimCF = CFrame.new(Camera.CFrame.Position, aimPos)
            local smooth = features.Aimbot.Smoothness / 100
            Camera.CFrame = Camera.CFrame:Lerp(aimCF, math.min(smooth * deltaTime * 30, 1))
        end
    end)
end

local triggerbotConnection
local function startTriggerbot()
    if triggerbotConnection then triggerbotConnection:Disconnect() end
    local lastFire = 0
    local isHolding = false
    triggerbotConnection = RunService.RenderStepped:Connect(function()
        if not features.Triggerbot.Enabled then return end
        local target = Mouse.Target
        if target and target:IsDescendantOf(Workspace) then
            local char = target:FindFirstAncestorWhichIsA("Model")
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            if humanoid and char:FindFirstChild("Head") then
                local player = Players:GetPlayerFromCharacter(char)
                if player and player ~= LocalPlayer then
                    if features.Aimbot.TeamCheck and player.Team == LocalPlayer.Team then return end
                    if features.Aimbot.WallCheck and aimbotWallCheck(char.Head.Position) then return end
                    local now = tick()
                    if features.Triggerbot.HoldMouse then
                        if not isHolding then
                            mouse1press()
                            isHolding = true
                        end
                    else
                        if now - lastFire > features.Triggerbot.Delay/1000 then
                            mouse1click()
                            lastFire = now
                        end
                    end
                end
            end
        else
            if isHolding then
                mouse1release()
                isHolding = false
            end
        end
    end)
end

-- ESP
local espObjects = {}
local function updateESP()
    for _, obj in pairs(espObjects) do
        if obj.Remove then obj:Remove() end
    end
    table.clear(espObjects)
    if not Drawing then return end
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char or not char:FindFirstChild("Head") then continue end
        local head = char.Head
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        local isTeam = player.Team == LocalPlayer.Team
        local color = isTeam and features.ESP.TeamColors.Team or features.ESP.TeamColors.Enemy
        if features.ESP.Rainbow then
            color = Color3.fromHSV(tick() % 6 / 6, 1, 1)
        end
        local pos3D = root.Position
        local headPos3D = head.Position
        local screenPos, onScreen = Camera:WorldToScreenPoint(pos3D)
        local headScreen, headVis = Camera:WorldToScreenPoint(headPos3D)
        if not onScreen or not headVis then continue end
        local height = (headScreen.Y - screenPos.Y) * 1.8
        local width = height / 2
        local x = screenPos.X - width/2
        local y = screenPos.Y
        if features.ESP.Box then
            local box = Drawing.new("Square")
            box.Visible = true
            box.Color = color
            box.Thickness = 1
            box.Filled = false
            box.Size = Vector2.new(width, height)
            box.Position = Vector2.new(x, y)
            table.insert(espObjects, box)
        end
        if features.ESP.CornerBox then
            local corners = {}
            for i=1,4 do
                local corner = Drawing.new("Line")
                corner.Visible = true
                corner.Color = color
                corner.Thickness = 1
                table.insert(corners, corner)
                table.insert(espObjects, corner)
            end
            -- simplistic corner drawing (outward facing)
            local len = 5
            corners[1].From = Vector2.new(x, y); corners[1].To = Vector2.new(x+len, y)
            corners[2].From = Vector2.new(x+width, y); corners[2].To = Vector2.new(x+width-len, y)
            corners[3].From = Vector2.new(x, y+height); corners[3].To = Vector2.new(x+len, y+height)
            corners[4].From = Vector2.new(x+width, y+height); corners[4].To = Vector2.new(x+width-len, y+height)
        end
        if features.ESP.Name then
            local name = Drawing.new("Text")
            name.Visible = true
            name.Text = player.Name
            name.Color = color
            name.Size = 13
            name.Center = true
            name.Position = Vector2.new(screenPos.X, screenPos.Y - 20)
            table.insert(espObjects, name)
        end
        if features.ESP.Distance then
            local dist = math.floor((LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and (LocalPlayer.Character.HumanoidRootPart.Position - root.Position).Magnitude) or 0)
            local distText = Drawing.new("Text")
            distText.Visible = true
            distText.Text = tostring(dist).." studs"
            distText.Color = color
            distText.Size = 12
            distText.Center = true
            distText.Position = Vector2.new(screenPos.X, screenPos.Y - 35)
            table.insert(espObjects, distText)
        end
        if features.ESP.HealthBar and char:FindFirstChildOfClass("Humanoid") then
            local health = char.Humanoid.Health / char.Humanoid.MaxHealth
            local barWidth = 2
            local barHeight = height
            local barX = x - 4
            local bar = Drawing.new("Line")
            bar.Visible = true
            bar.Color = Color3.fromRGB(255,0,0)
            bar.Thickness = barWidth
            bar.From = Vector2.new(barX, y + barHeight)
            bar.To = Vector2.new(barX, y + barHeight - barHeight * health)
            table.insert(espObjects, bar)
        end
        if features.ESP.Tracer then
            local tracer = Drawing.new("Line")
            tracer.Visible = true
            tracer.Color = color
            tracer.Thickness = 1
            tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
            tracer.To = Vector2.new(screenPos.X, screenPos.Y)
            table.insert(espObjects, tracer)
        end
        if features.ESP.Skeleton then
            -- simple skeleton from head to torso
            local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
            if torso then
                local torsoScreen = Camera:WorldToScreenPoint(torso.Position)
                local line = Drawing.new("Line")
                line.Visible = true
                line.Color = color
                line.Thickness = 1
                line.From = Vector2.new(headScreen.X, headScreen.Y)
                line.To = Vector2.new(torsoScreen.X, torsoScreen.Y)
                table.insert(espObjects, line)
            end
        end
        if features.ESP.WeaponName then
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then
                local wepText = Drawing.new("Text")
                wepText.Visible = true
                wepText.Text = tool.Name
                wepText.Color = color
                wepText.Size = 11
                wepText.Center = true
                wepText.Position = Vector2.new(screenPos.X, y + height + 5)
                table.insert(espObjects, wepText)
            end
        end
    end
end

-- Hitbox Expander visuals (circles around heads)
local hitboxCircles = {}
local function updateHitboxVisuals()
    for _, circle in pairs(hitboxCircles) do
        if circle.Remove then circle:Remove() end
    end
    table.clear(hitboxCircles)
    if not features.HitboxExpander.Enabled or not Drawing then return end
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if char and char:FindFirstChild("Head") then
            local screenPos, onScreen = Camera:WorldToScreenPoint(char.Head.Position)
            if onScreen then
                local circle = Drawing.new("Circle")
                circle.Visible = true
                circle.Color = Color3.fromRGB(255,255,0)
                circle.Thickness = 1
                circle.Radius = features.HitboxExpander.Size
                circle.Position = Vector2.new(screenPos.X, screenPos.Y)
                table.insert(hitboxCircles, circle)
            end
        end
    end
end

-- Movement
local flyConnection
local function startFly()
    if flyConnection then flyConnection:Disconnect() end
    if not features.Fly.Enabled then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.PlatformStand = false
        end
        return
    end
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.PlatformStand = true
    local bodyGyro = Instance.new("BodyGyro", char)
    bodyGyro.MaxTorque = Vector3.new(9e9,9e9,9e9)
    bodyGyro.P = 1000
    local bodyVel = Instance.new("BodyVelocity", char)
    bodyVel.MaxForce = Vector3.new(9e9,9e9,9e9)
    bodyVel.Velocity = Vector3.new()
    flyConnection = RunService.Heartbeat:Connect(function()
        if not features.Fly.Enabled then
            bodyGyro:Destroy()
            bodyVel:Destroy()
            humanoid.PlatformStand = false
            flyConnection:Disconnect()
            return
        end
        local moveDir = Vector3.new()
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0,1,0) end
        if moveDir.Magnitude > 0 then moveDir = moveDir.Unit end
        bodyVel.Velocity = moveDir * features.Fly.Speed
        bodyGyro.CFrame = CFrame.lookAt(char.HumanoidRootPart.Position, char.HumanoidRootPart.Position + Camera.CFrame.LookVector)
    end)
end

local function setWalkSpeed()
    local char = LocalPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.WalkSpeed = features.WalkSpeed.Enabled and features.WalkSpeed.Speed or 16
    end
end

local noclipConnection
local function startNoClip()
    if noclipConnection then noclipConnection:Disconnect() end
    if not features.NoClip then return end
    noclipConnection = RunService.Stepped:Connect(function()
        local char = LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
end

local bhopConnection
local function startBhop()
    if bhopConnection then bhopConnection:Disconnect() end
    if not features.Bhop then return end
    bhopConnection = RunService.Stepped:Connect(function()
        local char = LocalPlayer.Character
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid:GetState() == Enum.HumanoidStateType.Landed and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            humanoid.Jump = true
        end
    end)
end

-- Anti-Aim
local antiAimConnection
local function startAntiAim()
    if antiAimConnection then antiAimConnection:Disconnect() end
    if not features.AntiAim.Enabled then
        -- reset rotation if needed
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = CFrame.new(char.HumanoidRootPart.Position)
        end
        return
    end
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:WaitForChild("HumanoidRootPart")
    local originalCF = root.CFrame
    local jitterState = true
    antiAimConnection = RunService.RenderStepped:Connect(function(delta)
        if not features.AntiAim.Enabled then
            root.CFrame = originalCF
            return
        end
        local style = features.AntiAim.Style
        local speed = features.AntiAim.Speed
        local strength = math.rad(features.AntiAim.Strength)
        local mode = features.AntiAim.Mode
        local yaw = 0
        if style == "Jitter" then
            jitterState = not jitterState
            yaw = jitterState and strength or -strength
        elseif style == "Spin" then
            yaw = (tick() * speed) % (2*math.pi)
        elseif style == "Random Yaw" then
            yaw = math.random() * 2 * math.pi
        elseif style == "Desync" then
            yaw = strength * math.sin(tick() * speed)
        end
        local newCF = CFrame.new(root.Position) * CFrame.Angles(0, yaw, 0)
        root.CFrame = newCF
        if mode == "Full" and char:FindFirstChild("Head") then
            char.Head.CFrame = newCF * CFrame.new(0,1.5,0) -- rough head positioning
        end
    end)
end

-- Third Person
local thirdPersonConnection
local function startThirdPerson()
    if thirdPersonConnection then thirdPersonConnection:Disconnect() end
    if not features.ThirdPerson.Enabled then
        LocalPlayer.CameraMode = Enum.CameraMode.LockFirstPerson
        return
    end
    LocalPlayer.CameraMode = Enum.CameraMode.Classic
    thirdPersonConnection = RunService.RenderStepped:Connect(function()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("Head") then return end
        local headPos = char.Head.Position
        local camCFrame = CFrame.new(headPos) * CFrame.Angles(0, math.rad(180), 0) * CFrame.new(0,0,features.ThirdPerson.Distance)
        Camera.CFrame = camCFrame
        Camera.Focus = CFrame.new(headPos)
    end)
end

-- World
local function applyWorld()
    Lighting.Brightness = features.World.Fullbright and 2 or 1
    Lighting.ClockTime = 14
    Lighting.FogEnd = 10000
    Lighting.GlobalShadows = not features.World.Fullbright
    Workspace.Gravity = features.World.Gravity
    if features.World.DCM then
        local colorCorrection = Instance.new("ColorCorrectionEffect", Lighting)
        colorCorrection.Saturation = 1.5
        colorCorrection.Contrast = 1.2
        colorCorrection.Name = "ZynixDCM"
    else
        if Lighting:FindFirstChild("ZynixDCM") then Lighting.ZynixDCM:Destroy() end
    end
end

-- Hitsounds
local hitsoundSounds = {
    Bell = "rbxassetid://138199276",
    Ding = "rbxassetid://12222232",
    Quack = "rbxassetid://5769061391",
    Custom = "" -- fill from CustomID
}
local function playHitSound()
    if not features.Hitsounds.Enabled then return end
    local soundId = hitsoundSounds[features.Hitsounds.Sound] or ""
    if features.Hitsounds.Sound == "Custom" then
        soundId = "rbxassetid://" .. features.Hitsounds.CustomID
    end
    if soundId ~= "" then
        local sound = Instance.new("Sound")
        sound.SoundId = soundId
        sound.Volume = 0.5
        sound.Parent = Workspace
        sound:Play()
        game:GetService("Debris"):AddItem(sound, 2)
    end
end

-- Hook remote for hit detection (generic attempt)
local function hookHits()
    for _, remote in pairs(Workspace:GetDescendants()) do
        if remote:IsA("RemoteEvent") and (remote.Name == "Hit" or remote.Name == "DamageEvent" or remote.Name == "DealDamage") then
            local conn
            conn = remote.OnClientEvent:Connect(function(...)
                local args = {...}
                if args[1] == LocalPlayer.Character or (type(args[1])=="table" and args[1].Character == LocalPlayer.Character) then
                    playHitSound()
                end
            end)
            table.insert(env.connections, conn)
        end
    end
end

-- Triggerbot mouse simulation functions (replace with actual executor functions if available)
local mouse1press = (function()
    if syn and syn.presskey then
        return function() syn.presskey(Enum.KeyCode.MouseButton1) end
    elseif pcall(function() return getrenv().mouse1press end) then
        return getrenv().mouse1press
    else
        return function() Mouse.Button1Down:FireServer() end -- might not work
    end
end)()
local mouse1release = (function()
    if syn and syn.releasekey then
        return function() syn.releasekey(Enum.KeyCode.MouseButton1) end
    elseif pcall(function() return getrenv().mouse1release end) then
        return getrenv().mouse1release
    else
        return function() end
    end
end)()
local mouse1click = (function()
    if syn and syn.presskey and syn.releasekey then
        return function() syn.presskey(Enum.KeyCode.MouseButton1); task.wait(0.01); syn.releasekey(Enum.KeyCode.MouseButton1) end
    elseif pcall(function() return getrenv().mouse1click end) then
        return getrenv().mouse1click
    else
        return function() end
    end
end)()

