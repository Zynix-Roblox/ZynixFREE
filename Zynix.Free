-- Zynix | OverKill
-- Premium Roblox Cheat for OverKill (deckbuilder shooter)
-- UI: NeverLose CS2 inspired - Blue/White/Black theme with animations
-- Features: Aimbot, Triggerbot, Hitbox Expander, ESP, Movement, Anti-Aim, World, Hitsounds

--[[
   Key System
--]]
local key = "zynixoverkill"
local entered_key = nil
local gui_loaded = false

-- Simple key GUI
local function request_key()
    local key_gui = Instance.new("ScreenGui")
    key_gui.Name = "ZynixKey"
    key_gui.ResetOnSpawn = false
    key_gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    local bg = Instance.new("Frame", key_gui)
    bg.Size = UDim2.new(0,300,0,150)
    bg.Position = UDim2.new(0.5,-150,0.5,-75)
    bg.BackgroundColor3 = Color3.fromRGB(15,15,25)
    bg.BorderSizePixel = 0
    bg.Active = true
    bg.Draggable = true
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0,8)

    local title = Instance.new("TextLabel", bg)
    title.Size = UDim2.new(1,0,0,30)
    title.BackgroundTransparency = 1
    title.Text = "Zynix | OverKill"
    title.TextColor3 = Color3.fromRGB(255,255,255)
    title.TextSize = 18
    title.Font = Enum.Font.GothamBold
    title.Position = UDim2.new(0,0,0,10)

    local input = Instance.new("TextBox", bg)
    input.Size = UDim2.new(1,-40,0,30)
    input.Position = UDim2.new(0,20,0,50)
    input.BackgroundColor3 = Color3.fromRGB(25,25,35)
    input.TextColor3 = Color3.fromRGB(200,200,200)
    input.PlaceholderText = "Enter key..."
    input.Font = Enum.Font.Gotham
    input.TextSize = 14
    Instance.new("UICorner", input).CornerRadius = UDim.new(0,4)

    local submit = Instance.new("TextButton", bg)
    submit.Size = UDim2.new(1,-40,0,30)
    submit.Position = UDim2.new(0,20,0,95)
    submit.BackgroundColor3 = Color3.fromRGB(0,120,255)
    submit.TextColor3 = Color3.fromRGB(255,255,255)
    submit.Text = "Submit"
    submit.Font = Enum.Font.GothamBold
    submit.TextSize = 14
    Instance.new("UICorner", submit).CornerRadius = UDim.new(0,4)

    submit.MouseButton1Click:Connect(function()
        if input.Text == key then
            entered_key = true
            key_gui:Destroy()
        else
            input.Text = ""
            input.PlaceholderText = "Invalid key!"
        end
    end)

    input.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            if input.Text == key then
                entered_key = true
                key_gui:Destroy()
            else
                input.Text = ""
                input.PlaceholderText = "Invalid key!"
            end
        end
    end)
end

request_key()
repeat task.wait() until entered_key ~= nil
if not entered_key then return end

--[[
   Services and Variables
--]]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

local getgenv = getgenv or function() return {} end
local shared = getgenv()
shared.ZynixOverKill = shared.ZynixOverKill or {}
local env = shared.ZynixOverKill

-- Drawing API check
local Drawing = Drawing or (getrenv and getrenv().Drawing) or (shared.Drawing) or (syn and syn.protect_gui and loadstring("return Drawing")()) or nil
if not Drawing then
    warn("Drawing library not found. ESP will be disabled.")
end

--[[
   UI Library (NeverLose inspired)
--]]
local UILib = {}
UILib.__index = UILib

function UILib:CreateWindow(name)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "ZynixUI"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0,650,0,420)
    Main.Position = UDim2.new(0.5,-325,0.5,-210)
    Main.BackgroundColor3 = Color3.fromRGB(12,12,22)
    Main.BorderSizePixel = 0
    Main.Active = true
    Main.Draggable = true
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0,8)

    -- Gradient border effect
    local Border = Instance.new("Frame", Main)
    Border.Size = UDim2.new(1,4,1,4)
    Border.Position = UDim2.new(0,-2,0,-2)
    Border.BackgroundTransparency = 1
    Border.ZIndex = 0
    local stroke = Instance.new("UIStroke", Main)
    stroke.Thickness = 1.5
    stroke.Color = Color3.fromRGB(0,140,255)
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    -- Header
    local Header = Instance.new("Frame", Main)
    Header.Size = UDim2.new(1,0,0,40)
    Header.BackgroundColor3 = Color3.fromRGB(20,20,35)
    Header.BorderSizePixel = 0
    local headerGrad = Instance.new("UIGradient", Header)
    headerGrad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0,100,255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0,160,255))
    }
    local Title = Instance.new("TextLabel", Header)
    Title.Size = UDim2.new(1,0,1,0)
    Title.BackgroundTransparency = 1
    Title.Text = name or "Zynix | OverKill"
    Title.TextColor3 = Color3.fromRGB(255,255,255)
    Title.TextSize = 18
    Title.Font = Enum.Font.GothamBold
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Position = UDim2.new(0,15,0,0)
    local glow = Instance.new("UIStroke", Title)
    glow.Thickness = 0.8
    glow.Color = Color3.fromRGB(0,180,255)
    glow.ApplyStrokeMode = Enum.ApplyStrokeMode.Contextual

    -- Tab buttons container
    local TabButtons = Instance.new("ScrollingFrame", Main)
    TabButtons.Size = UDim2.new(0,140,1,-40)
    TabButtons.Position = UDim2.new(0,0,0,40)
    TabButtons.BackgroundColor3 = Color3.fromRGB(18,18,30)
    TabButtons.BorderSizePixel = 0
    TabButtons.ScrollBarThickness = 2
    TabButtons.ScrollBarImageColor3 = Color3.fromRGB(0,140,255)
    TabButtons.CanvasSize = UDim2.new(0,0,0,0)
    local UIListLayout = Instance.new("UIListLayout", TabButtons)
    UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    UIListLayout.Padding = UDim.new(0,2)

    -- Content area
    local Content = Instance.new("Frame", Main)
    Content.Size = UDim2.new(1,-140,1,-40)
    Content.Position = UDim2.new(0,140,0,40)
    Content.BackgroundColor3 = Color3.fromRGB(15,15,25)
    Content.BorderSizePixel = 0

    -- Animation for opening/closing (slide effect)
    local openTween = TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0.5,-325,0.5,-210)})
    local closeTween = TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(0.5,-325,1,100)})
    local isOpen = true

    local window = {
        ScreenGui = ScreenGui,
        Main = Main,
        Content = Content,
        TabButtons = TabButtons,
        Tabs = {},
        ActiveTab = nil,
        isOpen = isOpen,
        openTween = openTween,
        closeTween = closeTween
    }
    setmetatable(window, UILib)

    -- Toggle menu keybind (Right Shift or Left Alt)
    local function toggleMenu()
        window.isOpen = not window.isOpen
        if window.isOpen then
            Main.Visible = true
            openTween:Play()
        else
            closeTween:Play()
            closeTween.Completed:Wait()
            Main.Visible = false
        end
    end

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.RightShift or input.KeyCode == Enum.KeyCode.LeftAlt then
            toggleMenu()
        end
    end)

    -- Close button
    local CloseBtn = Instance.new("TextButton", Header)
    CloseBtn.Size = UDim2.new(0,30,0,30)
    CloseBtn.Position = UDim2.new(1,-35,0,5)
    CloseBtn.BackgroundColor3 = Color3.fromRGB(255,70,70)
    CloseBtn.Text = "X"
    CloseBtn.TextColor3 = Color3.fromRGB(255,255,255)
    CloseBtn.TextSize = 16
    CloseBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", CloseBtn).CornerRadius = UDim.new(0,4)
    CloseBtn.MouseButton1Click:Connect(function()
        Main.Visible = false
        window.isOpen = false
    end)

    return window
end

function UILib:CreateTab(name)
    local tabBtn = Instance.new("TextButton")
    tabBtn.Size = UDim2.new(1,-10,0,32)
    tabBtn.Position = UDim2.new(0,5,0,0)
    tabBtn.BackgroundColor3 = Color3.fromRGB(25,25,40)
    tabBtn.Text = name
    tabBtn.TextColor3 = Color3.fromRGB(180,180,200)
    tabBtn.Font = Enum.Font.Gotham
    tabBtn.TextSize = 14
    tabBtn.TextXAlignment = Enum.TextXAlignment.Left
    tabBtn.TextXOffset = 10
    tabBtn.BorderSizePixel = 0
    Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0,4)
    
    local highlight = Instance.new("Frame", tabBtn)
    highlight.Size = UDim2.new(0,3,1,0)
    highlight.Position = UDim2.new(0,0,0,0)
    highlight.BackgroundColor3 = Color3.fromRGB(0,140,255)
    highlight.Visible = false

    local tabFrame = Instance.new("Frame", self.Content)
    tabFrame.Size = UDim2.new(1,0,1,0)
    tabFrame.BackgroundTransparency = 1
    tabFrame.Visible = false

    table.insert(self.Tabs, {button = tabBtn, frame = tabFrame, highlight = highlight})
    tabBtn.Parent = self.TabButtons
    self.TabButtons.CanvasSize = UDim2.new(0,0,0,UIListLayout.AbsoluteContentSize.Y + 10)

    local function selectTab()
        for _, tab in pairs(self.Tabs) do
            tab.frame.Visible = false
            tab.highlight.Visible = false
            tab.button.TextColor3 = Color3.fromRGB(180,180,200)
            tab.button.BackgroundColor3 = Color3.fromRGB(25,25,40)
        end
        tabFrame.Visible = true
        highlight.Visible = true
        tabBtn.TextColor3 = Color3.fromRGB(255,255,255)
        tabBtn.BackgroundColor3 = Color3.fromRGB(35,35,50)
        self.ActiveTab = tabFrame
    end

    tabBtn.MouseButton1Click:Connect(selectTab)
    if #self.Tabs == 1 then selectTab() end

    return {
        frame = tabFrame,
        AddSection = function(self2, sectionName)
            local section = Instance.new("Frame", tabFrame)
            section.Size = UDim2.new(1,-20,0,24)
            section.Position = UDim2.new(0,10,0,10) -- will be adjusted by layout
            section.BackgroundTransparency = 1
            local label = Instance.new("TextLabel", section)
            label.Size = UDim2.new(1,0,1,0)
            label.BackgroundTransparency = 1
            label.Text = sectionName
            label.TextColor3 = Color3.fromRGB(0,150,255)
            label.TextSize = 13
            label.Font = Enum.Font.GothamBold
            label.TextXAlignment = Enum.TextXAlignment.Left
            return section
        end,
        AddToggle = function(self2, name, default, callback)
            local container = Instance.new("Frame", tabFrame)
            container.Size = UDim2.new(1,-20,0,28)
            container.BackgroundTransparency = 1
            local label = Instance.new("TextLabel", container)
            label.Size = UDim2.new(0,200,1,0)
            label.BackgroundTransparency = 1
            label.Text = name
            label.TextColor3 = Color3.fromRGB(220,220,230)
            label.TextSize = 13
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left
            local toggleBg = Instance.new("Frame", container)
            toggleBg.Size = UDim2.new(0,36,0,18)
            toggleBg.Position = UDim2.new(1,-40,0.5,-9)
            toggleBg.BackgroundColor3 = default and Color3.fromRGB(0,140,255) or Color3.fromRGB(50,50,60)
            toggleBg.BorderSizePixel = 0
            Instance.new("UICorner", toggleBg).CornerRadius = UDim.new(1,0)
            local toggleCircle = Instance.new("Frame", toggleBg)
            toggleCircle.Size = UDim2.new(0,14,0,14)
            toggleCircle.Position = default and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
            toggleCircle.BackgroundColor3 = Color3.fromRGB(255,255,255)
            Instance.new("UICorner", toggleCircle).CornerRadius = UDim.new(1,0)
            local state = default
            local function update(val)
                state = val
                local goalPos = val and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
                TweenService:Create(toggleCircle, TweenInfo.new(0.2), {Position = goalPos}):Play()
                toggleBg.BackgroundColor3 = val and Color3.fromRGB(0,140,255) or Color3.fromRGB(50,50,60)
                if callback then callback(val) end
            end
            toggleBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    update(not state)
                end
            end)
            return {SetValue = update, GetValue = function() return state end}
        end,
        AddSlider = function(self2, name, min, max, default, callback)
            local container = Instance.new("Frame", tabFrame)
            container.Size = UDim2.new(1,-20,0,40)
            container.BackgroundTransparency = 1
            local label = Instance.new("TextLabel", container)
            label.Size = UDim2.new(1,0,0,16)
            label.BackgroundTransparency = 1
            label.Text = name .. ": " .. tostring(default)
            label.TextColor3 = Color3.fromRGB(220,220,230)
            label.TextSize = 12
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left
            local sliderBg = Instance.new("Frame", container)
            sliderBg.Size = UDim2.new(1,0,0,12)
            sliderBg.Position = UDim2.new(0,0,0,22)
            sliderBg.BackgroundColor3 = Color3.fromRGB(40,40,50)
            sliderBg.BorderSizePixel = 0
            Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(0,4)
            local fill = Instance.new("Frame", sliderBg)
            fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
            fill.BackgroundColor3 = Color3.fromRGB(0,140,255)
            fill.BorderSizePixel = 0
            Instance.new("UICorner", fill).CornerRadius = UDim.new(0,4)
            local current = default
            local function set(val)
                current = math.clamp(val, min, max)
                fill.Size = UDim2.new((current-min)/(max-min),0,1,0)
                label.Text = name .. ": " .. math.floor(current * 10 + 0.5)/10
                if callback then callback(current) end
            end
            local dragging = false
            sliderBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    local mousePos = UserInputService:GetMouseLocation()
                    local absSize = sliderBg.AbsoluteSize
                    local absPos = sliderBg.AbsolutePosition
                    local relX = mousePos.X - absPos.X
                    local ratio = math.clamp(relX / absSize.X, 0, 1)
                    set(min + ratio * (max - min))
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local mousePos = UserInputService:GetMouseLocation()
                    local absSize = sliderBg.AbsoluteSize
                    local absPos = sliderBg.AbsolutePosition
                    local relX = mousePos.X - absPos.X
                    local ratio = math.clamp(relX / absSize.X, 0, 1)
                    set(min + ratio * (max - min))
                end
            end)
            return {SetValue = set, GetValue = function() return current end}
        end,
        AddDropdown = function(self2, name, options, default, callback)
            local container = Instance.new("Frame", tabFrame)
            container.Size = UDim2.new(1,-20,0,28)
            container.BackgroundTransparency = 1
            local label = Instance.new("TextLabel", container)
            label.Size = UDim2.new(0,120,1,0)
            label.BackgroundTransparency = 1
            label.Text = name
            label.TextColor3 = Color3.fromRGB(220,220,230)
            label.TextSize = 13
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left
            local btn = Instance.new("TextButton", container)
            btn.Size = UDim2.new(1,-130,1,0)
            btn.Position = UDim2.new(0,130,0,0)
            btn.BackgroundColor3 = Color3.fromRGB(30,30,40)
            btn.Text = default or options[1]
            btn.TextColor3 = Color3.fromRGB(255,255,255)
            btn.TextSize = 12
            btn.Font = Enum.Font.Gotham
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.TextXOffset = 5
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0,4)
            local list = Instance.new("Frame", container)
            list.Size = UDim2.new(1,-130,0,0)
            list.Position = UDim2.new(0,130,1,2)
            list.BackgroundColor3 = Color3.fromRGB(25,25,35)
            list.BorderSizePixel = 0
            list.Visible = false
            list.ZIndex = 10
            local listLayout = Instance.new("UIListLayout", list)
            local scroll = Instance.new("ScrollingFrame", list)
            scroll.Size = UDim2.new(1,0,1,0)
            scroll.BackgroundTransparency = 1
            scroll.CanvasSize = UDim2.new(0,0,0,0)
            local selected = default or options[1]
            local function updateSelection(val)
                selected = val
                btn.Text = val
                list.Visible = false
                if callback then callback(val) end
            end
            for _, opt in pairs(options) do
                local optBtn = Instance.new("TextButton", scroll)
                optBtn.Size = UDim2.new(1,0,0,22)
                optBtn.BackgroundColor3 = Color3.fromRGB(35,35,45)
                optBtn.Text = opt
                optBtn.TextColor3 = Color3.fromRGB(200,200,200)
                optBtn.Font = Enum.Font.Gotham
                optBtn.TextSize = 12
                optBtn.MouseButton1Click:Connect(function() updateSelection(opt) end)
                scroll.CanvasSize = UDim2.new(0,0,0,scroll.CanvasSize.Y.Offset + 22)
            end
            btn.MouseButton1Click:Connect(function()
                list.Visible = not list.Visible
                if list.Visible then
                    list.Size = UDim2.new(1,-130,0,scroll.CanvasSize.Y.Offset)
                end
            end)
            return {GetValue = function() return selected end, SetValue = updateSelection}
        end,
        AddKeybind = function(self2, name, defaultKey, callback)
            local container = Instance.new("Frame", tabFrame)
            container.Size = UDim2.new(1,-20,0,28)
            container.BackgroundTransparency = 1
            local label = Instance.new("TextLabel", container)
            label.Size = UDim2.new(0,120,1,0)
            label.BackgroundTransparency = 1
            label.Text = name
            label.TextColor3 = Color3.fromRGB(220,220,230)
            label.TextSize = 13
            label.Font = Enum.Font.Gotham
            local keyBtn = Instance.new("TextButton", container)
            keyBtn.Size = UDim2.new(1,-130,1,0)
            keyBtn.Position = UDim2.new(0,130,0,0)
            keyBtn.BackgroundColor3 = Color3.fromRGB(30,30,40)
            keyBtn.Text = defaultKey and defaultKey.Name or "None"
            keyBtn.TextColor3 = Color3.fromRGB(255,255,255)
            keyBtn.Font = Enum.Font.Gotham
            keyBtn.TextSize = 12
            Instance.new("UICorner", keyBtn).CornerRadius = UDim.new(0,4)
            local currentKey = defaultKey
            local waiting = false
            keyBtn.MouseButton1Click:Connect(function()
                waiting = true
                keyBtn.Text = "..."
            end)
            local inputConn
            inputConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if waiting and not gameProcessed then
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey = input.KeyCode
                        keyBtn.Text = currentKey.Name
                        waiting = false
                        if callback then callback(currentKey) end
                    end
                end
            end)
            return {GetValue = function() return currentKey end}
        end,
        AddColorPicker = function(self2, name, default, callback) -- minimal color selector (predefined)
            local container = Instance.new("Frame", tabFrame)
            container.Size = UDim2.new(1,-20,0,28)
            container.BackgroundTransparency = 1
            local label = Instance.new("TextLabel", container)
            label.Size = UDim2.new(0,100,1,0)
            label.BackgroundTransparency = 1
            label.Text = name
            label.TextColor3 = Color3.fromRGB(220,220,230)
            label.TextSize = 13
            label.Font = Enum.Font.Gotham
            local colorFrame = Instance.new("Frame", container)
            colorFrame.Size = UDim2.new(1,-110,1,0)
            colorFrame.Position = UDim2.new(0,110,0,0)
            colorFrame.BackgroundColor3 = default or Color3.fromRGB(255,0,0)
            Instance.new("UICorner", colorFrame).CornerRadius = UDim.new(0,4)
            local colors = {Color3.fromRGB(255,0,0), Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255), Color3.fromRGB(255,255,0), Color3.fromRGB(255,0,255), Color3.fromRGB(0,255,255)}
            local function updateCol(col)
                colorFrame.BackgroundColor3 = col
                if callback then callback(col) end
            end
            colorFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    updateCol(colors[math.random(1,#colors)]) -- cycle on click
                end
            end)
            return {SetValue = updateCol, GetValue = function() return colorFrame.BackgroundColor3 end}
        end
    }
end

