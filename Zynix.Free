--// UI Engine -----------------------------------------------------------------
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "Zynix_FREE"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global

local function makeVisuals(obj, r, t, c)
    local corner = Instance.new("UICorner", obj)
    corner.CornerRadius = UDim.new(0, r)
    local stroke = Instance.new("UIStroke", obj)
    stroke.Thickness = t
    stroke.Color = c
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return stroke
end

local function animateTitle(label)
    local grad = Instance.new("UIGradient", label)
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, CONFIG.Accent),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 80, 200)),
        ColorSequenceKeypoint.new(1, CONFIG.Accent)
    })
    grad.Rotation = 0
    task.spawn(function()
        while label.Parent do
            grad.Rotation = (grad.Rotation + 1.5) % 360
            RunService.RenderStepped:Wait()
        end
    end)
end

local function drag(frame)
    local dragging, startPos, dragStart
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

