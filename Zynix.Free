-- ==================== UI ELEMENT CREATORS ====================
local function addToggle(page, text, stateKey, order)
    local f = Instance.new("Frame", page)
    f.Size = UDim2.new(0.95, 0, 0, 42)
    f.BackgroundColor3 = CONFIG.Background
    createVisuals(f, 8, 1, CONFIG.Outline)
    f.LayoutOrder = order

    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(0.75, 0, 1, 0)
    l.Position = UDim2.new(0, 12, 0, 0)
    l.BackgroundTransparency = 1
    l.Font = CONFIG.FontSmall
    l.Text = text
    l.TextColor3 = CONFIG.Text
    l.TextSize = 14
    l.TextXAlignment = Enum.TextXAlignment.Left

    local b = Instance.new("TextButton", f)
    b.Size = UDim2.new(0, 52, 0, 26)
    b.Position = UDim2.new(1, -62, 0.5, 0)
    b.AnchorPoint = Vector2new(0, 0.5)
    b.BackgroundColor3 = State[stateKey] and CONFIG.Accent or CONFIG.Secondary
    b.Text = ""
    createVisuals(b, 13, 1, CONFIG.Outline)

    b.MouseButton1Click:Connect(function()
        State[stateKey] = not State[stateKey]
        TweenService:Create(b, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundColor3 = State[stateKey] and CONFIG.Accent or CONFIG.Secondary}):Play()
    end)
end

local function addSlider(page, text, stateKey, min, max, def, decimals, order)
    local f = Instance.new("Frame", page)
    f.Size = UDim2.new(0.95, 0, 0, 60)
    f.BackgroundColor3 = CONFIG.Background
    createVisuals(f, 8, 1, CONFIG.Outline)
    f.LayoutOrder = order

    if State[stateKey] == nil then State[stateKey] = def end

    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(1, -20, 0, 26)
    l.Position = UDim2.new(0, 12, 0, 4)
    l.BackgroundTransparency = 1
    l.Font = CONFIG.FontSmall
    l.Text = text .. ": " .. (decimals and string.format("%."..decimals.."f", State[stateKey]) or State[stateKey])
    l.TextColor3 = CONFIG.Text
    l.TextSize = 13
    l.TextXAlignment = Enum.TextXAlignment.Left

    local bg = Instance.new("Frame", f)
    bg.Size = UDim2.new(0.85, 0, 0, 8)
    bg.Position = UDim2.new(0.5, 0, 0.75, 0)
    bg.AnchorPoint = Vector2new(0.5, 0.5)
    bg.BackgroundColor3 = CONFIG.Secondary
    createVisuals(bg, 4, 1, CONFIG.Outline)

    local fill = Instance.new("Frame", bg)
    fill.Size = UDim2.new((State[stateKey] - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = CONFIG.Accent
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 4)

    local knob = Instance.new("Frame", f)
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new(0.5 + ((State[stateKey] - min) / (max - min) * 0.85) - 0.425, 0, 0.75, -7)
    knob.BackgroundColor3 = CONFIG.AccentLight
    Instance.new("UICorner", knob).CornerRadius = UDim.new(0, 7)

    local function update(input)
        local p = mathclamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        fill.Size = UDim2.new(p, 0, 1, 0)
        local val = min + (max - min) * p
        if decimals then
            val = math.floor(val * 10^decimals + 0.5) / 10^decimals
        else
            val = math.floor(val)
        end
        State[stateKey] = val
        l.Text = text .. ": " .. (decimals and string.format("%."..decimals.."f", val) or val)
        knob.Position = UDim2.new(0.5 + p * 0.85 - 0.425, 0, 0.75, -7)
    end

    local dragging = false
    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input)
        end
    end)
end

local function addDropdown(page, text, stateKey, options, order)
    local f = Instance.new("Frame", page)
    f.Size = UDim2.new(0.95, 0, 0, 42)
    f.BackgroundColor3 = CONFIG.Background
    createVisuals(f, 8, 1, CONFIG.Outline)
    f.LayoutOrder = order

    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(0.65, 0, 1, 0)
    l.Position = UDim2.new(0, 12, 0, 0)
    l.BackgroundTransparency = 1
    l.Font = CONFIG.FontSmall
    l.Text = text
    l.TextColor3 = CONFIG.Text
    l.TextSize = 14
    l.TextXAlignment = Enum.TextXAlignment.Left

    local b = Instance.new("TextButton", f)
    b.Size = UDim2.new(0, 90, 0, 28)
    b.Position = UDim2.new(1, -100, 0.5, 0)
    b.AnchorPoint = Vector2new(0, 0.5)
    b.BackgroundColor3 = CONFIG.Secondary
    b.Font = CONFIG.FontSmall
    b.Text = State[stateKey] or options[1]
    b.TextColor3 = CONFIG.Text
    b.TextSize = 12
    createVisuals(b, 8, 1, CONFIG.Outline)

    local currIdx = table.find(options, State[stateKey]) or 1
    b.MouseButton1Click:Connect(function()
        currIdx = currIdx % #options + 1
        State[stateKey] = options[currIdx]
        b.Text = State[stateKey]
    end)
end

